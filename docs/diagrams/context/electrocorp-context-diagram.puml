@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam wrapWidth 180
skinparam maxMessageSize 90
skinparam ArrowColor #6B6B6B
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 1
skinparam packageStyle rectangle
skinparam packageBorderColor #555555
skinparam packageBackgroundColor transparent
skinparam packageFontColor #444444
skinparam packageFontStyle bold
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
hide stereotype
title ElectroCorp - C4 Context Diagram
left to right direction


rectangle "Home Owner\n[Person]\n\nManages home devices, routines, energy usage and alerts." as HomeOwner #0B5593
rectangle "Business Owner\n[Person]\n\nManages business locations, devices, reports, support and billing." as BusinessOwner #0B5593

package "ElectroCorp Digital Ecosystem\n[system boundary]" {
  rectangle "ElectroCorp Website\n[Public Website]\n\nPresents value proposition, plans and calls to action." as Landing #0B6FB3
  rectangle "ElectroCorp Web Application\n[Angular SPA]\n\nOperational product used after sign up or login." as WebApp #0B6FB3
  rectangle "ElectroCorp Platform API\n[Spring Boot System]\n\nCoordinates IAM, billing, workplaces, devices, energy, alerts, reports and service." as Platform #0B6FB3
}

rectangle "Payment Provider\n[External System]\n\nProcesses subscription payments and checkout status." as PaymentProvider #7F8C8D
rectangle "Email / Notification Provider\n[External System]\n\nDelivers alerts, reports and support notifications." as NotificationProvider #7F8C8D
database "ElectroCorp Database\n[Relational Database]\n\nStores users, plans, workplaces, devices, readings, alerts, reports and tickets." as Database

HomeOwner --> Landing : Visits
BusinessOwner --> Landing : Compares plans
Landing --> WebApp : Redirects selected plan
HomeOwner --> WebApp : Uses platform
BusinessOwner --> WebApp : Uses platform
WebApp --> Platform : Consumes REST API (JSON / HTTPS)
Platform --> Database : Reads and writes (JPA / SQL)
Platform --> PaymentProvider : Processes billing
Platform --> NotificationProvider : Sends notifications
legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#9B59B6> domain |
  |<#F39C12> repository / external |
  |<#C9332B> database |
endlegend
@enduml
