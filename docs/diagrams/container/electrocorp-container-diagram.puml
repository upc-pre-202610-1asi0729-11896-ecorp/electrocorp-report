@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 145
skinparam maxMessageSize 95
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam ArrowThickness 1
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle plain
skinparam rectangle {
  BorderThickness 0
}
skinparam rectangle<<BoundedContext>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
}
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
skinparam databaseFontStyle plain
hide stereotype
left to right direction

title ElectroCorp - C4 Container Diagram

rectangle "<b>ElectroCorp User</b>\n<i>[Person]</i>\n\nUses smart energy management flows across website and web app." as User #0B5593

rectangle "<b>ElectroCorp Product Boundary</b>\n<i>[Software System]</i>" as Product <<BoundedContext>> {
  rectangle "<b>Landing Page</b>\n<i>[Static Website]</i>\n\nPublic marketing site hosted on GitHub Pages." as Website #3498DB
  rectangle "<b>Angular Web App</b>\n<i>[Frontend Container]</i>\n\nSPA with routes, layout, facades, stores and API clients." as Spa #3498DB
  rectangle "<b>Backend API</b>\n<i>[Backend Container]</i>\n\nSpring Boot modular monolith organized by DDD bounded contexts." as Api #3498DB
  database "<b>ElectroCorp Database</b>\n<i>[PostgreSQL Container]</i>\n\nPersists operational and analytical platform data." as Db
}

rectangle "<b>GitHub Pages</b>\n<i>[External Container]</i>\n\nHosts the public website." as GithubPages #7F8C8D
rectangle "<b>Render Web Service</b>\n<i>[External Container]</i>\n\nHosts Angular and Spring Boot deployments." as RenderWeb #7F8C8D
rectangle "<b>Payment Provider</b>\n<i>[External System]</i>\n\nSupports subscription payment flow." as Payment #7F8C8D
rectangle "<b>Email Provider</b>\n<i>[External System]</i>\n\nSupports notification delivery." as Mail #7F8C8D

User --> Website : Browses plans\n[Browser]
Website --> Spa : Redirects chosen plan\n[HTTPS]
User --> Spa : Uses product features\n[Browser]
Spa --> Api : Consumes REST endpoints\n[JSON / HTTPS]
Api --> Db : Reads and writes\n[JPA / SQL]
Website --> GithubPages : Is deployed on\n[Static hosting]
Spa --> RenderWeb : Is deployed on\n[Web service]
Api --> RenderWeb : Is deployed on\n[Web service]
Api --> Payment : Requests payment status\n[HTTPS / API]
Api --> Mail : Sends alerts and reports\n[HTTPS / API]

Website -[hidden]right- Spa
Spa -[hidden]right- Api
Api -[hidden]right- Db
GithubPages -[hidden]down- RenderWeb
Payment -[hidden]down- Mail

legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#F39C12> infrastructure / external |
  |<#C9332B> database |
  |<#7F8C8D> external container |
endlegend

@enduml
