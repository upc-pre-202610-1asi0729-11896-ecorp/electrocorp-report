@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 220
skinparam maxMessageSize 130
skinparam nodesep 70
skinparam ranksep 80
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam ArrowThickness 1
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle plain
skinparam rectangle {
  BorderThickness 0
  MinimumWidth 190
  Padding 12
}
skinparam database {
  MinimumWidth 210
  Padding 12
}
skinparam rectangle<<SystemBoundary>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
  MinimumWidth 760
  Padding 18
}
skinparam rectangle<<BoundedContext>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
  MinimumWidth 760
  Padding 18
}
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
skinparam databaseFontStyle plain
hide stereotype
left to right direction

title ElectroCorp - C4 Container Diagram

rectangle "<b>ElectroCorp User</b>\n<i>[Person]</i>\n\nUses public and authenticated\nenergy management flows." as User #0B5593

rectangle "<b>ElectroCorp Product Boundary</b>\n<i>[Software System]</i>" as Product <<SystemBoundary>> {
  rectangle "<b>Landing Page</b>\n<i>[Static Website]</i>\n\nPublic site for value proposition, plans and call-to-action flows." as Website #3498DB
  rectangle "<b>ElectroCorp WebApp</b>\n<i>[Angular Source App]</i>\n\nFrontend application source with routes, views, facades, stores and API clients." as WebApp #3498DB
  rectangle "<b>ElectroCorp SPA</b>\n<i>[Compiled Angular SPA]</i>\n\nBrowser runtime produced from the WebApp build and served as static files." as Spa #3498DB
  rectangle "<b>Backend API</b>\n<i>[Spring Boot Container]</i>\n\nSpring Boot modular monolith organized by DDD bounded contexts." as Api #3498DB
  database "<b>ElectroCorp Database</b>\n<i>[PostgreSQL Container]</i>\n\nPersists users, plans, workplaces, devices, readings, reports and tickets." as Db
}

rectangle "<b>GitHub Pages</b>\n<i>[External Container]</i>\n\nHosts the landing page." as GithubPages #7F8C8D
rectangle "<b>Render Static Site</b>\n<i>[External Container]</i>\n\nServes the compiled SPA." as RenderSpa #7F8C8D
rectangle "<b>Render Web Service</b>\n<i>[External Container]</i>\n\nRuns the backend API." as RenderApi #7F8C8D
rectangle "<b>Payment Provider</b>\n<i>[External System]</i>\n\nSupports subscription\npayment flow." as Payment #7F8C8D
rectangle "<b>Email Provider</b>\n<i>[External System]</i>\n\nSupports alert and\nreport delivery." as Mail #7F8C8D

User --> Website : Browses plans\n[Browser]
Website --> Spa : Redirects selected\nplan\n[CTA Link]
User --> Spa : Opens app directly\n[Browser]
WebApp --> Spa : Builds into\n[Angular build]
Spa --> Api : Consumes REST\nendpoints\n[JSON / HTTPS]
Api --> Db : Reads and writes\n[JPA / SQL]
Website --> GithubPages : Deployed on\n[Static hosting]
Spa --> RenderSpa : Served by\n[Static site]
Api --> RenderApi : Runs on\n[Web service]
Api --> Payment : Checks payment\nstatus\n[HTTPS / API]
Api --> Mail : Sends messages\n[HTTPS / API]

Website -[hidden]right- WebApp
WebApp -[hidden]right- Spa
Spa -[hidden]right- Api
Api -[hidden]right- Db
GithubPages -[hidden]down- RenderSpa
RenderSpa -[hidden]down- RenderApi
Payment -[hidden]down- Mail

legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#F39C12> infrastructure / external |
  |<#C9332B> database |
  |<#7F8C8D> external container |
endlegend

@enduml
