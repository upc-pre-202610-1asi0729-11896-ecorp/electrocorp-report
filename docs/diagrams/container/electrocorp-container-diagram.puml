@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam wrapWidth 180
skinparam maxMessageSize 90
skinparam ArrowColor #6B6B6B
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 1
skinparam packageStyle rectangle
skinparam packageBorderColor #555555
skinparam packageBackgroundColor transparent
skinparam packageFontColor #444444
skinparam packageFontStyle bold
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
hide stereotype
title ElectroCorp - C4 Container Diagram
left to right direction


rectangle "ElectroCorp User\n[Person]\n\nUses smart energy management flows across website and web app." as User <#0B5593>

package "ElectroCorp Product Boundary\n[software system]" {
  rectangle "Landing Page\n[Static Website]\n\nPublic marketing site hosted on GitHub Pages." as Website <#3498DB>
  rectangle "Angular Web App\n[Container]\n\nSPA with routes, layout, facades, stores and API clients." as Spa <#3498DB>
  rectangle "Backend API\n[Container]\n\nSpring Boot modular monolith organized by DDD bounded contexts." as Api <#3498DB>
  database "ElectroCorp Database\n[Relational Database]\n\nPersists operational and analytical platform data." as Db
}

rectangle "GitHub Pages\n[External Container]\n\nHosts the public website." as GithubPages <#7F8C8D>
rectangle "Render Web Service\n[External Container]\n\nHosts Angular and Spring Boot deployments." as RenderWeb <#7F8C8D>
rectangle "Payment Provider\n[External System]\n\nSupports subscription payment flow." as Payment <#7F8C8D>
rectangle "Email Provider\n[External System]\n\nSupports notification delivery." as Mail <#7F8C8D>

User --> Website : Reads product information
Website --> Spa : Redirects to sign up / selected plan
User --> Spa : Navigates authenticated features
Spa --> Api : Uses REST endpoints (JSON / HTTPS)
Api --> Db : Reads and writes (JPA / SQL)
Api --> Payment : Uses checkout and payment APIs
Api --> Mail : Sends alerts and reports
GithubPages --> Website : Hosts
RenderWeb --> Spa : Hosts
RenderWeb --> Api : Hosts
legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#9B59B6> domain |
  |<#F39C12> repository / external |
  |<#C9332B> database |
endlegend
@enduml
