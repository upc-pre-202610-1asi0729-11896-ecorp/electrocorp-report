@startuml
!pragma layout smetana
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam wrapWidth 180
skinparam maxMessageSize 90
skinparam ArrowColor #6B6B6B
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangle {
  RoundCorner 0
  BorderThickness 1
}
skinparam package {
  BorderColor #555555
  BorderStyle dashed
  BackgroundColor transparent
  FontColor #444444
  FontStyle bold
}
skinparam database {
  BackgroundColor #C9332B
  BorderColor #C9332B
  FontColor #FFFFFF
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #FFFFFF
}
hide stereotype
title ElectroCorp - C4 Container Diagram
left to right direction


rectangle "<b>ElectroCorp User</b>
<size:12><i>[Person]</i></size>

Uses smart energy management flows across website and web app." as User <#0B5593>

package "ElectroCorp Product Boundary
[software system]" {
  rectangle "<b>Landing Page</b>
<size:12><i>[Static Website]</i></size>

Public marketing site hosted on GitHub Pages." as Website <#3498DB>
  rectangle "<b>Angular Web App</b>
<size:12><i>[Container]</i></size>

SPA with routes, layout, facades, stores and API clients." as Spa <#3498DB>
  rectangle "<b>Backend API</b>
<size:12><i>[Container]</i></size>

Spring Boot modular monolith organized by DDD bounded contexts." as Api <#3498DB>
  database "<b>ElectroCorp Database</b>
<size:12><i>[Relational Database]</i></size>

Persists operational and analytical platform data." as Db
}

rectangle "<b>GitHub Pages</b>
<size:12><i>[External Container]</i></size>

Hosts the public website." as GithubPages <#7F8C8D>
rectangle "<b>Render Web Service</b>
<size:12><i>[External Container]</i></size>

Hosts Angular and Spring Boot deployments." as RenderWeb <#7F8C8D>
rectangle "<b>Payment Provider</b>
<size:12><i>[External System]</i></size>

Supports subscription payment flow." as Payment <#7F8C8D>
rectangle "<b>Email Provider</b>
<size:12><i>[External System]</i></size>

Supports notification delivery." as Mail <#7F8C8D>

User --> Website : Reads product information
Website --> Spa : Redirects to sign up / selected plan
User --> Spa : Navigates authenticated features
Spa --> Api : Uses REST endpoints (JSON / HTTPS)
Api --> Db : Reads and writes (JPA / SQL)
Api --> Payment : Uses checkout and payment APIs
Api --> Mail : Sends alerts and reports
GithubPages --> Website : Hosts
RenderWeb --> Spa : Hosts
RenderWeb --> Api : Hosts
legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#9B59B6> domain |
  |<#F39C12> repository / external |
  |<#C9332B> database |
endlegend
@enduml
