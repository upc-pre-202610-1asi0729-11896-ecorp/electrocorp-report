@startuml
title ElectroCorp Platform - IAM Backend Class Diagram
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "IAM" {
  package "Application / Results" {
    class "AuthenticationResult" as Backend_iam_AuthenticationResult <<record>> {
      + User user
      + String token
    }
  }
  package "Application / Services" {
    class "AuthApplicationService" as Backend_iam_AuthApplicationService <<Application Service>> {
      - userRepository: UserRepository
      - accessProfileRepository: AccessProfileRepository
      - passwordEncoder: PasswordEncoder
      - jwtTokenService: JwtTokenService
      + signUp(SignUpCommand command) : AuthenticationResult
      + signIn(SignInCommand command) : AuthenticationResult
      + getAuthenticatedUser(Long userId) : User
      + signOut() : void
      + recoverPassword(RecoverPasswordCommand command) : void
    }
    class "UserApplicationService" as Backend_iam_UserApplicationService <<Application Service>> {
      - userRepository: UserRepository
      + getProfile(Long userId) : User
      + updateProfile(Long userId, UpdateProfileCommand command) : User
      + deleteAccount(Long userId) : void
      - findUser(Long userId) : User
    }
  }
  package "Domain / Aggregates" {
    class "AccessProfile" as Backend_iam_AccessProfile <<Aggregate>> {
      - name: String
      - description: String
    }
    class "User" as Backend_iam_User <<Aggregate>> {
      - fullName: String
      - email: String
      - passwordHash: String
      - status: AccountStatus
      - accessProfile: AccessProfile
      + deactivate() : void
      + isActive() : boolean
    }
  }
  package "Domain / Commands" {
    class "DeleteAccountCommand" as Backend_iam_DeleteAccountCommand <<record>> {
      + Long userId
    }
    class "RecoverPasswordCommand" as Backend_iam_RecoverPasswordCommand <<record>> {
      + String email
    }
    class "SignInCommand" as Backend_iam_SignInCommand <<record>> {
      + String email
      + String password
    }
    class "SignUpCommand" as Backend_iam_SignUpCommand <<record>> {
      + String fullName
      + String email
      + String password
    }
    class "UpdateProfileCommand" as Backend_iam_UpdateProfileCommand <<record>> {
      + String fullName
      + String email
    }
  }
  package "Domain / Events" {
    class "UserRegisteredEvent" as Backend_iam_UserRegisteredEvent <<record>> {
      + Long userId
      + String email
      + LocalDateTime occurredOn
      + UserRegisteredEvent(Long userId, String email, LocalDateTime occurredOn) : record
      + UserRegisteredEvent(Long userId, String email)
    }
  }
  package "Domain / Model" {
    enum "AccountStatus" as Backend_iam_AccountStatus <<enum>> {
      + ACTIVE
      + INACTIVE
    }
  }
  package "Domain / Repositories" {
    interface "AccessProfileRepository" as Backend_iam_AccessProfileRepository <<interface>> {
    }
    interface "UserRepository" as Backend_iam_UserRepository <<interface>> {
    }
  }
  package "Domain / Services" {
    class "EmailPolicyService" as Backend_iam_EmailPolicyService <<Domain Service>> {
      + isAllowedEmail(String email) : boolean
    }
    class "PasswordPolicyService" as Backend_iam_PasswordPolicyService <<Domain Service>> {
      + isValid(String password) : boolean
    }
    class "UserProfilePolicyService" as Backend_iam_UserProfilePolicyService <<Domain Service>> {
      + validateFullName(String fullName) : void
      + validateEmail(String email) : void
    }
  }
  package "Domain / Value Objects" {
    class "AccessProfileName" as Backend_iam_AccessProfileName <<record>> {
      + String value
      + AccessProfileName(String value) : record
    }
    class "PasswordHash" as Backend_iam_PasswordHash <<record>> {
      + String value
      + PasswordHash(String value) : record
    }
    class "RoleName" as Backend_iam_RoleName <<record>> {
      + String value
      + RoleName(String value) : record
      - PATTERN: Pattern
    }
  }
  package "Infrastructure / JPA" {
    class "for" as Backend_iam_for <<Class>> {
    }
  }
  package "Infrastructure / JPA Repositories" {
    interface "JpaAccessProfileRepository" as Backend_iam_JpaAccessProfileRepository <<interface>> {
    }
    interface "JpaUserRepository" as Backend_iam_JpaUserRepository <<interface>> {
    }
  }
  package "Infrastructure / Security" {
    class "CurrentSessionService" as Backend_iam_CurrentSessionService <<Security>> {
      - currentUserProvider: CurrentUserProvider
      + getCurrentUserIdOrDefault() : Long
    }
    class "JwtAuthenticationFilter" as Backend_iam_JwtAuthenticationFilter <<Security>> {
      - BEARER_PREFIX: String
      - jwtTokenService: JwtTokenService
    }
    class "JwtTokenService" as Backend_iam_JwtTokenService <<Security>> {
      - HMAC_ALGORITHM: String
      - BASE64_URL_ENCODER: Base64.Encoder
      - BASE64_URL_DECODER: Base64.Decoder
      - SUBJECT_PATTERN: Pattern
      - EXPIRATION_PATTERN: Pattern
      - secret: String
      - expirationSeconds: long
      + generateToken(User user) : String
      + validateAndGetUserId(String token) : Optional<Long>
      - encode(String value) : String
      - sign(String value) : String
      - constantTimeEquals(String left, String right) : boolean
      - escapeJson(String value) : String
    }
    class "MessageDigestHelper" as Backend_iam_MessageDigestHelper <<Security>> {
      - MessageDigestHelper()
    }
    class "PasswordHashingService" as Backend_iam_PasswordHashingService <<Security>> {
      - passwordEncoder: PasswordEncoder
      + hash(String rawPassword) : String
      + matches(String rawPassword, String encodedPassword) : boolean
    }
  }
  package "Interfaces / REST Assemblers" {
    class "AuthResourceFromResultAssembler" as Backend_iam_AuthResourceFromResultAssembler <<Assembler>> {
      - AuthResourceFromResultAssembler()
      + toResourceFromResult(AuthenticationResult result) : AuthResource
    }
    class "RecoverPasswordCommandFromResourceAssembler" as Backend_iam_RecoverPasswordCommandFromResourceAssembler <<Assembler>> {
      - RecoverPasswordCommandFromResourceAssembler()
      + toCommandFromResource(RecoverPasswordResource resource) : RecoverPasswordCommand
    }
    class "SignInCommandFromResourceAssembler" as Backend_iam_SignInCommandFromResourceAssembler <<Assembler>> {
      - SignInCommandFromResourceAssembler()
      + toCommandFromResource(SignInResource resource) : SignInCommand
    }
    class "SignUpCommandFromResourceAssembler" as Backend_iam_SignUpCommandFromResourceAssembler <<Assembler>> {
      - SignUpCommandFromResourceAssembler()
      + toCommandFromResource(SignUpResource resource) : SignUpCommand
    }
    class "UpdateProfileCommandFromResourceAssembler" as Backend_iam_UpdateProfileCommandFromResourceAssembler <<Assembler>> {
      - UpdateProfileCommandFromResourceAssembler()
      + toCommandFromResource(UpdateProfileResource resource) : UpdateProfileCommand
    }
    class "UserResourceFromEntityAssembler" as Backend_iam_UserResourceFromEntityAssembler <<Assembler>> {
      - UserResourceFromEntityAssembler()
      + toResourceFromEntity(User entity) : UserResource
    }
  }
  package "Interfaces / REST Controllers" {
    class "AuthController" as Backend_iam_AuthController <<REST Controller>> {
      - authApplicationService: AuthApplicationService
      - currentUserProvider: CurrentUserProvider
      + signUp(SignUpResource request) : AuthResource
      + signIn(SignInResource request) : AuthResource
      + signOut() : void
      + recoverPassword(RecoverPasswordResource request) : void
      + me() : UserResource
    }
    class "UserController" as Backend_iam_UserController <<REST Controller>> {
      - userApplicationService: UserApplicationService
      - currentUserProvider: CurrentUserProvider
      + getCurrentUserProfile() : UserResource
      + updateCurrentUserProfile(UpdateProfileResource request) : UserResource
      + deleteCurrentUserAccount() : void
      + getProfile(Long userId) : UserResource
      + updateProfile(Long userId, UpdateProfileResource request) : UserResource
      + deleteAccount(Long userId) : void
    }
  }
  package "Interfaces / REST Resources" {
    class "AuthResource" as Backend_iam_AuthResource <<record>> {
      + UserResource user
      + String token
    }
    class "RecoverPasswordResource" as Backend_iam_RecoverPasswordResource <<record>> {
      + String email
    }
    class "SignInResource" as Backend_iam_SignInResource <<record>> {
      + String email
      + String password
    }
    class "SignUpResource" as Backend_iam_SignUpResource <<record>> {
      + String fullName
      + String email
      + (min = 8
    }
    class "UpdateProfileResource" as Backend_iam_UpdateProfileResource <<record>> {
      + String fullName
      + String email
    }
    class "UserResource" as Backend_iam_UserResource <<record>> {
      + Long id
      + String fullName
      + String email
      + Long accessProfileId
      + String accessProfileName
      + String status
      + from(User user) : UserResource
    }
  }
}

