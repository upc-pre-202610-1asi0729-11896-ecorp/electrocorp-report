@startuml
title ElectroCorp Platform - Billing Backend Application Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Billing / Application" {
  package "Application / Command Services" {
    interface "BillingCommandService" as Backend_billing_BillingCommandService <<interface>> {
    }
  }
  package "Application / Command Services Impl" {
    class "BillingCommandServiceImpl" as Backend_billing_BillingCommandServiceImpl <<Command Service>> {
      - planRepository: PlanRepository
      - subscriptionRepository: SubscriptionRepository
      - paymentRepository: PaymentRepository
      - invoiceRepository: InvoiceRepository
      - paymentValidationService: PaymentValidationService
      - paymentGatewayPort: PaymentGatewayPort
      + handle(CheckoutSubscriptionCommand command) : Subscription
      + handle(CancelSubscriptionCommand command) : void
      + handle(ProcessPaymentCommand command) : Payment
      - validatePaymentDetails(CheckoutSubscriptionCommand command) : void
    }
  }
  package "Application / Gateways" {
    interface "PaymentGatewayPort" as Backend_billing_PaymentGatewayPort <<Port>> {
      + charge(PaymentGatewayChargeRequest request) : PaymentGatewayChargeResult
    }
    class "PaymentGatewayChargeRequest" as Backend_billing_PaymentGatewayChargeRequest <<record>> {
      + Long userId
      + String planCode
      + Money amount
      + String holderName
      + String cardNumber
      + String expirationDate
    }
    class "PaymentGatewayChargeResult" as Backend_billing_PaymentGatewayChargeResult <<record>> {
      + boolean approved
      + String provider
      + String transactionId
      + String statusMessage
    }
  }
  package "Application / Event Handlers" {
    class "SubscriptionActivatedEventHandler" as Backend_billing_SubscriptionActivatedEventHandler <<Event Handler>> {
      - integrationEventPublisher: IntegrationEventPublisher
      + on(SubscriptionActivatedEvent event) : void
    }
    class "PaymentRegisteredEventHandler" as Backend_billing_PaymentRegisteredEventHandler <<Event Handler>> {
      - integrationEventPublisher: IntegrationEventPublisher
      + on(PaymentRegisteredEvent event) : void
    }
  }
  package "Application / Query Services" {
    interface "BillingQueryService" as Backend_billing_BillingQueryService <<interface>> {
    }
  }
  package "Application / Query Services Impl" {
    class "BillingQueryServiceImpl" as Backend_billing_BillingQueryServiceImpl <<Query Service>> {
      - planRepository: PlanRepository
      - subscriptionRepository: SubscriptionRepository
      - paymentRepository: PaymentRepository
      - invoiceRepository: InvoiceRepository
      + handle(GetAllPlansQuery query) : List<Plan>
      + handle(GetCurrentSubscriptionQuery query) : Optional<Subscription>
      + handle(GetPaymentsByUserQuery query) : List<Payment>
      + handle(GetInvoicesByUserQuery query) : List<Invoice>
    }
  }
}

Backend_billing_BillingCommandServiceImpl ..> Backend_billing_BillingCommandService
Backend_billing_BillingCommandServiceImpl ..> Backend_billing_PaymentGatewayPort
Backend_billing_PaymentGatewayPort ..> Backend_billing_PaymentGatewayChargeRequest
Backend_billing_PaymentGatewayPort ..> Backend_billing_PaymentGatewayChargeResult
Backend_billing_SubscriptionActivatedEventHandler ..> Backend_billing_BillingCommandServiceImpl : after commit
Backend_billing_PaymentRegisteredEventHandler ..> Backend_billing_BillingCommandServiceImpl : after commit
Backend_billing_BillingQueryServiceImpl ..> Backend_billing_BillingQueryService


@enduml
