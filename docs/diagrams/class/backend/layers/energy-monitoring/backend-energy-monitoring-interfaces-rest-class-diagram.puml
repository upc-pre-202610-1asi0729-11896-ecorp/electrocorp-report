@startuml
title ElectroCorp Platform - Energy Monitoring Backend Interfaces REST Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Energy Monitoring / Interfaces REST" {
  package "Interfaces / REST Assemblers" {
    class "CreateEnergyReadingCommandFromResourceAssembler" as Backend_energymonitoring_CreateEnergyReadingCommandFromResourceAssembler <<Assembler>> {
      + toCommandFromResource(CreateEnergyReadingResource resource, Long userId) : CreateEnergyReadingCommand
    }
    class "EnergyReadingResourceFromEntityAssembler" as Backend_energymonitoring_EnergyReadingResourceFromEntityAssembler <<Assembler>> {
      + toResourceFromEntity(EnergyReading reading) : EnergyReadingResource
    }
  }
  package "Interfaces / REST Controllers" {
    class "EnergyMonitoringController" as Backend_energymonitoring_EnergyMonitoringController <<REST Controller>> {
      - commandService: EnergyMonitoringCommandService
      - queryService: EnergyMonitoringQueryService
      - currentUserProvider: CurrentUserProvider
      + getDashboardSummary() : EnergyDashboardSummaryResource
      + getSamplingSettings() : EnergySamplingSettingsResource
      + createReading(CreateEnergyReadingResource request) : EnergyReadingResource
      - parseStart(String value) : LocalDateTime
      - parseEnd(String value) : LocalDateTime
    }
  }
  package "Interfaces / REST Resources" {
    class "CreateEnergyReadingResource" as Backend_energymonitoring_CreateEnergyReadingResource <<record>> {
      + Long deviceId
      + String deviceName
      + BigDecimal watts
    }
    class "EnergyDashboardSummaryResource" as Backend_energymonitoring_EnergyDashboardSummaryResource <<record>> {
      + BigDecimal currentWatts
      + BigDecimal todayKilowattHours
      + BigDecimal todayEstimatedCost
      + BigDecimal projectedMonthlyCost
      + BigDecimal costPerHour
      + BigDecimal peakWatts
      + BigDecimal averageWatts
      + Integer activeDevices
      + Integer monitoredDevices
      + Integer normalReadings
      + Integer highReadings
      + Integer efficiencyScore
      + String operationalStatus
      + String recommendation
      + Integer activeAlerts
      + Integer criticalAlerts
      + String latestAlertLevel
      + String latestAlertTitle
      + List<TrendPoint> trend
      + List<DeviceConsumption> topDevices
      + List<RoomConsumption> rooms
      + List<ActiveDevice> activeDeviceDetails
    }
    class "EnergyReadingResource" as Backend_energymonitoring_EnergyReadingResource <<record>> {
      + Long id
      + Long userId
      + Long deviceId
      + String deviceName
      + BigDecimal watts
      + BigDecimal kilowattHours
      + BigDecimal estimatedCost
      + Integer sampleSeconds
      + LocalDateTime recordedAt
      + String status
      + from(EnergyReading reading) : EnergyReadingResource
    }
    class "EnergySamplingSettingsResource" as Backend_energymonitoring_EnergySamplingSettingsResource <<record>> {
      + Integer sampleSeconds
    }
    class "UpdateEnergySamplingSettingsResource" as Backend_energymonitoring_UpdateEnergySamplingSettingsResource <<record>> {
      + (5
    }
  }
}

Backend_energymonitoring_CreateEnergyReadingCommandFromResourceAssembler ..> Backend_energymonitoring_CreateEnergyReadingResource
Backend_energymonitoring_EnergyMonitoringController ..> Backend_energymonitoring_CreateEnergyReadingCommandFromResourceAssembler
Backend_energymonitoring_EnergyMonitoringController ..> Backend_energymonitoring_CreateEnergyReadingResource
Backend_energymonitoring_EnergyMonitoringController ..> Backend_energymonitoring_EnergyDashboardSummaryResource
Backend_energymonitoring_EnergyMonitoringController ..> Backend_energymonitoring_EnergyReadingResource
Backend_energymonitoring_EnergyMonitoringController ..> Backend_energymonitoring_EnergyReadingResourceFromEntityAssembler
Backend_energymonitoring_EnergyMonitoringController ..> Backend_energymonitoring_EnergySamplingSettingsResource
Backend_energymonitoring_EnergyMonitoringController ..> Backend_energymonitoring_UpdateEnergySamplingSettingsResource
Backend_energymonitoring_EnergyReadingResourceFromEntityAssembler ..> Backend_energymonitoring_EnergyReadingResource


@enduml
