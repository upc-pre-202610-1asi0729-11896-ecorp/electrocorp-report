@startuml
title ElectroCorp Platform - Shared Kernel Backend Application Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Shared Kernel / Application" {
  package "Application / Events" {
    interface "DomainEventPublisher" as Backend_shared_DomainEventPublisher <<interface>> {
      + publish(DomainEvent event) : void
    }
    interface "IntegrationEvent" as Backend_shared_IntegrationEvent <<interface>> {
      + occurredOn() : LocalDateTime
    }
    interface "IntegrationEventPublisher" as Backend_shared_IntegrationEventPublisher <<interface>> {
      + publish(IntegrationEvent event) : void
    }
  }
  package "Application / Results" {
    class "Result" as Backend_shared_Result <<Class>> {
      - success: TSuccess
      - failure: TFailure
      - successful: boolean
      - Result(TSuccess success, TFailure failure, boolean successful)
      + success(TSuccess value) : <TSuccess, TFailure> Result<TSuccess, TFailure>
      + failure(TFailure value) : <TSuccess, TFailure> Result<TSuccess, TFailure>
      + isSuccess() : boolean
      + isFailure() : boolean
      + success() : TSuccess
      + failure() : TFailure
    }
  }
  package "Application / Services" {
    class "DateTimeService" as Backend_shared_DateTimeService <<Application Service>> {
      + today() : LocalDate
      + now() : LocalDateTime
    }
    class "StringNormalizerService" as Backend_shared_StringNormalizerService <<Application Service>> {
      + normalizeText(String value) : String
      + normalizeEmail(String email) : String
    }
  }
}



' Layer relationship completion: every declared type participates in this layer diagram.
Backend_shared_DateTimeService ..> Backend_shared_DomainEventPublisher
Backend_shared_IntegrationEventPublisher ..> Backend_shared_IntegrationEvent
Backend_shared_DateTimeService ..> Backend_shared_Result
Backend_shared_DateTimeService ..> Backend_shared_StringNormalizerService

@enduml
