@startuml
title ElectroCorp Web App - Reporting Presentation Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "Reporting Presentation" {
  package "Presentation / Components" {
    interface "EnergyGoalInsight" as FrontendPresentation_reporting_EnergyGoalInsight <<interface>> {
      + measuredKilowattHours: number
      + estimatedCost: number
      + devicesMeasured: number
      + daysRemaining: number
      + expectedProgressPercentage: number
      + projectedKilowattHours: number
      + statusLabel: string
      + statusTone: 'good' | 'warning' | 'danger'
      + recommendation: string
    }
    class "GoalProgressCardComponent" as FrontendPresentation_reporting_GoalProgressCardComponent <<Component>> {
      + goal: !: EnergyGoal
      + insight: !: EnergyGoalInsight
      + remove
      + constructor: (
      - translate: TranslateService
      - uiPreferences: UiPreferencesService
      + get: progressPercentage(): number
      + get: remainingKilowattHours(): number
      + get: projectedPercentage(): number
      + onRemove() : void
      + formatNumber(value: number, decimals = 2) : string
      + formatDate(value: string) : string
      + activeWindowLabel() : string
      + daysRemainingLabel() : string
      - t(key: string, params?: Record<string, unknown>) : string
      - currentLocale() : string
    }
    class "MonthlyComparisonChartComponent" as FrontendPresentation_reporting_MonthlyComparisonChartComponent <<Component>> {
      - _reports: ConsumptionReport[]
      + set: reports(value: ConsumptionReport[] | null)
      + get: reports(): ConsumptionReport[]
      + reportSelected
      + selectedPeriod: ConsumptionReportPeriod
      + chartReports: ConsumptionReport[]
      + chartItems: DraggableBarCarouselItem[]
      - chartMaxWatts
      - languageChangeSubscription: Subscription
      + periodOptions: DropdownOption[]
      + constructor: (
      - translate: TranslateService
      - uiPreferences: UiPreferencesService
      + ngOnDestroy() : void
      + get: filteredReports(): ConsumptionReport[]
      + getBarPercentage(totalWatts: number) : number
      + selectReport(report: ConsumptionReport) : void
      + selectCarouselItem(item: DraggableBarCarouselItem) : void
    }
    class "ReportCardComponent" as FrontendPresentation_reporting_ReportCardComponent <<Component>> {
      + report: !: ConsumptionReport
      + exported
      + remove
      + constructor: (
      - translate: TranslateService
      - uiPreferences: UiPreferencesService
      + onExport() : void
      + onRemove() : void
      + getCleanTitle() : string
      + periodLabel(period: ConsumptionReportPeriod) : string
      + formatWatts(value: number) : string
      + formatDate(value: string) : string
      - t(key: string, params?: Record<string, unknown>) : string
      - currentLocale() : string
      - dateFromInput(value: string) : Date
    }
  }
  package "Presentation / Pages" {
    class "EnergyGoalsPageComponent" as FrontendPresentation_reporting_EnergyGoalsPageComponent <<Component>> {
      + createModalOpen
      + title
      + targetKilowattHours: number | null
      + deadline
      + scopeType: EnergyGoalScopeType
      + scopeTargetId
      + activeFrom
      + activeTo
      + scopeOptions: DropdownOption[]
      + constructor: (
      + reportingFacade: ReportingFacade
      + deviceControlFacade: DeviceControlFacade
      + workplaceFacade: WorkplaceFacade
      - activeWorkplaceContext: ActiveWorkplaceContextService
      - confirmDialogService: ConfirmDialogService
      - toastService: ToastService
      - translate: TranslateService
      - uiPreferences: UiPreferencesService
    }
    class "ReportsPageComponent" as FrontendPresentation_reporting_ReportsPageComponent <<Component>> {
      + title
      + period: ConsumptionReportPeriod
      + selectedReport: ConsumptionReport | null
      + isReportDetailClosing
      + rangeOptions: TimeRangeOption[]
      - lockedScrollY
      - reportDetailCloseTimeout: ReturnType<typeof setTimeout> | null
      - reportDetailCloseAnimationMs
      - languageChangeSubscription: Subscription
      + periods: ConsumptionReportPeriod[]
      + constructor: (
      + reportingFacade: ReportingFacade
      - changeDetectorRef: ChangeDetectorRef
      - toastService: ToastService
      - translate: TranslateService
      - uiPreferences: UiPreferencesService
      - document: Document
      + ngOnInit() : Promise<void>
    }
  }
  package "Presentation / Routes" {
    class "REPORTING_ROUTES" as FrontendPresentation_reporting_REPORTING_ROUTES <<Routes>> {
      + route: /energy/reports
    }
  }
}

FrontendPresentation_reporting_EnergyGoalsPageComponent ..> FrontendPresentation_reporting_EnergyGoalInsight
FrontendPresentation_reporting_EnergyGoalsPageComponent ..> FrontendPresentation_reporting_GoalProgressCardComponent
FrontendPresentation_reporting_ReportsPageComponent ..> FrontendPresentation_reporting_MonthlyComparisonChartComponent
FrontendPresentation_reporting_ReportsPageComponent ..> FrontendPresentation_reporting_ReportCardComponent

@enduml
