@startuml
title ElectroCorp Web App - IAM Frontend Class Diagram
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "IAM" {
  package "Application / Commands" {
    interface "DeleteAccountCommand" as Frontend_iam_DeleteAccountCommand <<interface>> {
      + confirmation: string
    }
    interface "RecoverPasswordCommand" as Frontend_iam_RecoverPasswordCommand <<interface>> {
      + email: string
    }
    interface "SignInCommand" as Frontend_iam_SignInCommand <<interface>> {
      + email: string
      + password: string
    }
    interface "SignUpCommand" as Frontend_iam_SignUpCommand <<interface>> {
      + fullName: string
      + email: string
      + password: string
    }
    interface "UpdateProfileCommand" as Frontend_iam_UpdateProfileCommand <<interface>> {
      + fullName: string
      + email: string
    }
  }
  package "Application / Facades and Services" {
    class "IamFacade" as Frontend_iam_IamFacade <<Facade>> {
      - userAssembler
      + get: currentUser()
      + get: loading()
      + get: error()
      + get: isAuthenticated()
      + constructor: (
      - authApi: AuthApiService
      - usersApi: UsersApiService
      - authSession: AuthSessionService
      - router: Router
      - store: IamStore
      + signIn(command: SignInCommand) : Promise<boolean>
      + async: signUp(
      + command: SignUpCommand
      + options: SignUpOptions
      + restoreSession() : Promise<boolean>
      + signOut() : Promise<void>
      + recoverPassword(command: RecoverPasswordCommand) : Promise<boolean>
    }
  }
  package "Application / Stores" {
    class "IamStore" as Frontend_iam_IamStore <<Store>> {
      - currentUserSignal
      - loadingSignal
      - errorSignal
      + setCurrentUser(user: User | null) : void
      + setLoading(value: boolean) : void
      + setError(value: string | null) : void
      + clearMessages() : void
      + reset() : void
    }
  }
  package "Domain / Model" {
    class "AccessProfile" as Frontend_iam_AccessProfile <<Entity>> {
      - _name: AccessProfileName
      - _description: string
      + constructor: (props:
      + get: name(): AccessProfileName
      + get: description(): string
      + get: isOwner(): boolean
      + get: isAdmin(): boolean
      + get: isMember(): boolean
      + get: isGuest(): boolean
    }
    class "AccessProfileName" as Frontend_iam_AccessProfileName <<type>> {
      + 'OWNER' | 'ADMIN' | 'MEMBER' | 'GUEST'
    }
    class "User" as Frontend_iam_User <<Entity>> {
      - _fullName: string
      - _email: string
      - _accessProfileId: number
      - _accessProfileName: string
      - _createdAt: string
      + constructor: (props:
      + get: fullName(): string
      + get: email(): string
      + get: accessProfileId(): number
      + get: accessProfileName(): string
      + get: createdAt(): string
      + get: initials(): string
    }
  }
  package "Infrastructure / API Services" {
    class "AccessProfilesApiService" as Frontend_iam_AccessProfilesApiService <<API Service>> {
      + constructor: (
      + http: HttpClient
      + apiBaseUrl: string
    }
    class "AuthApiService" as Frontend_iam_AuthApiService <<API Service>> {
      - authUrl: string
      + constructor: (
      - http: HttpClient
      - apiBaseUrl: string
      + signIn(resource: SignInResource) : Observable<AuthResponse>
      + signUp(resource: SignUpResource) : Observable<AuthResponse>
      + signOut() : Observable<void>
      + me() : Observable<UserResponse>
      + recoverPassword(email: string) : Observable<void>
    }
    class "IamApiService" as Frontend_iam_IamApiService <<API Service>> {
      + constructor(authApi: AuthApiService)
    }
    class "UsersApiService" as Frontend_iam_UsersApiService <<API Service>> {
      + constructor: (
      + http: HttpClient
      + apiBaseUrl: string
      + getCurrentProfile() : Observable<UserResponse>
      + updateCurrentProfile(resource: UserResource) : Observable<UserResponse>
      + deleteCurrentAccount() : Observable<void>
      + updateProfile(userId: number, resource: UserResource) : Observable<UserResponse>
      + deleteAccount(userId: number) : Observable<void>
    }
  }
  package "Infrastructure / Assemblers" {
    class "AccessProfileAssembler" as Frontend_iam_AccessProfileAssembler <<Assembler>> {
      + override: toEntity(response: AccessProfileResponse): AccessProfile
      + override: toResource(entity: AccessProfile): AccessProfileResource
    }
    class "UserAssembler" as Frontend_iam_UserAssembler <<Assembler>> {
      + override: toEntity(response: UserResponse): User
      + override: toResource(entity: User): UserResource
    }
  }
  package "Infrastructure / Resources" {
    interface "AccessProfileResource" as Frontend_iam_AccessProfileResource <<interface>> {
      + name: AccessProfileName
      + description: string
    }
    interface "SignInResource" as Frontend_iam_SignInResource <<interface>> {
      + email: string
      + password: string
    }
    interface "SignUpResource" as Frontend_iam_SignUpResource <<interface>> {
      + fullName: string
      + email: string
      + password: string
    }
    interface "UserResource" as Frontend_iam_UserResource <<interface>> {
      + fullName: string
      + email: string
      + accessProfileId?: number
    }
  }
  package "Infrastructure / Responses" {
    interface "AccessProfileResponse" as Frontend_iam_AccessProfileResponse <<interface>> {
      + name: AccessProfileName
      + description: string
    }
    interface "AuthResponse" as Frontend_iam_AuthResponse <<interface>> {
      + user: UserResponse
      + token: string
      + message?: string
    }
    interface "UserResponse" as Frontend_iam_UserResponse <<interface>> {
      + fullName: string
      + email: string
      + accessProfileId: number
      + accessProfileName: string
      + createdAt: string
    }
  }
  package "Presentation / Pages" {
    class "AccountPageComponent" as Frontend_iam_AccountPageComponent <<Component>> {
      + constructor: (
      + iamFacade: IamFacade
      - uiPreferences: UiPreferencesService
      - translate: TranslateService
      + get: userInitials(): string
      + formatDate(value: string | undefined) : string
      + currentLocale() : string
      - t(key: string) : string
    }
    class "LoginPageComponent" as Frontend_iam_LoginPageComponent <<Component>> {
      + email
      + password
      + constructor: (
      + iamFacade: IamFacade
      - toastService: ToastService
      + onSubmit() : Promise<void>
    }
    class "PlatformPageComponent" as Frontend_iam_PlatformPageComponent <<Component>> {
      + languageOptions: DropdownOption[]
      + constructor: (
      + uiPreferences: UiPreferencesService
      - toastService: ToastService
      - translate: TranslateService
      + get: currentLanguage(): string
      + get: currentLanguageLabel(): string
      + get: currentThemeLabel(): string
      + selectLanguage(value: string) : void
      + setDarkMode(enabled: boolean) : void
      - t(key: string) : string
    }
    class "ProfilePageComponent" as Frontend_iam_ProfilePageComponent <<Component>> {
      + fullName
      + email
      + constructor: (
      + iamFacade: IamFacade
      - toastService: ToastService
      - translate: TranslateService
      + ngOnInit() : void
      + onUpdateProfile() : Promise<void>
      + hasPendingChanges() : boolean
      - t(key: string) : string
    }
    class "RecoverPasswordPageComponent" as Frontend_iam_RecoverPasswordPageComponent <<Component>> {
      + email
      + constructor: (
      + iamFacade: IamFacade
      - toastService: ToastService
      + onSubmit() : Promise<void>
    }
    class "RegisterPageComponent" as Frontend_iam_RegisterPageComponent <<Component>> {
      + fullName
      + email
      + password
      + selectedLandingPlan: LandingSelectedPlan | null
      + constructor: (
      + iamFacade: IamFacade
      + billingFacade: BillingFacade
      - route: ActivatedRoute
      - router: Router
      - toastService: ToastService
      + ngOnInit() : void
      + get: passwordRequirements()
      + get: passwordIsValid(): boolean
      + get: registrationIsLoading(): boolean
      + onSubmit() : Promise<void>
      - activateSelectedLandingPlan() : Promise<void>
      - isPlanCode(value: string | null) : value is PlanCode
      - getDefaultPlanName(planCode: PlanCode) : string
    }
    class "SecurityPageComponent" as Frontend_iam_SecurityPageComponent <<Component>> {
      + constructor: (
      + iamFacade: IamFacade
      - toastService: ToastService
      - confirmDialog: ConfirmDialogService
      - translate: TranslateService
      + get: email(): string
      + sendRecovery() : Promise<void>
      + onDeleteAccount() : Promise<void>
      - t(key: string) : string
    }
  }
  package "Presentation / Routes" {
    class "IamRoutes" as Frontend_iam_IamRoutes <<Routes>> {
      + Routes
    }
  }
}

