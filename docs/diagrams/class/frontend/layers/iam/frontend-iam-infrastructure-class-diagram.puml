@startuml
title ElectroCorp Web App - IAM Frontend Infrastructure Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "IAM / Infrastructure" {
  package "Infrastructure / API Services" {
    class "AccessProfilesApiService" as Frontend_iam_AccessProfilesApiService <<API Service>> {
      + findAllProfiles() : Observable<AccessProfileResponse[]>
    }
    class "AuthApiService" as Frontend_iam_AuthApiService <<API Service>> {
      - authUrl: string
      + signIn(resource: SignInResource) : Observable<AuthResponse>
      + signUp(resource: SignUpResource) : Observable<AuthResponse>
      + signOut() : Observable<void>
      + me() : Observable<UserResponse>
      + recoverPassword(email: string) : Observable<void>
      + resetPassword(resource: ResetPasswordResource) : Observable<void>
    }
    class "IamApiService" as Frontend_iam_IamApiService <<API Service>> {
      + constructor(authApi: AuthApiService)
    }
    class "UsersApiService" as Frontend_iam_UsersApiService <<API Service>> {
      + getCurrentProfile() : Observable<UserResponse>
      + findManagedUsers() : Observable<UserResponse[]>
      + updateCurrentProfile(resource: UserResource) : Observable<UserResponse>
      + deleteCurrentAccount() : Observable<void>
      + updateProfile(userId: number, resource: UserResource) : Observable<UserResponse>
      + deleteAccount(userId: number) : Observable<void>
      + assignAccessProfile(userId: number, resource: AssignAccessProfileResource) : Observable<UserResponse>
    }
  }
  package "Infrastructure / Assemblers" {
    class "AccessProfileAssembler" as Frontend_iam_AccessProfileAssembler <<Assembler>> {
      + toEntity(response: AccessProfileResponse) : AccessProfile
      + toResource(entity: AccessProfile) : AccessProfileResource
    }
    class "UserAssembler" as Frontend_iam_UserAssembler <<Assembler>> {
      + toEntity(response: UserResponse) : User
      + toResource(entity: User) : UserResource
    }
  }
  package "Infrastructure / Resources" {
    interface "AccessProfileResource" as Frontend_iam_AccessProfileResource <<Resource>> {
      + id: number
      + name: AccessProfileName
      + description: string
      + permissions: AccessPermission[]
    }
    interface "AssignAccessProfileResource" as Frontend_iam_AssignAccessProfileResource <<Resource>> {
      + accessProfileId: number
    }
    interface "ResetPasswordResource" as Frontend_iam_ResetPasswordResource <<Resource>> {
      + token: string
      + password: string
    }
    interface "SignInResource" as Frontend_iam_SignInResource <<Resource>> {
      + email: string
      + password: string
    }
    interface "SignUpResource" as Frontend_iam_SignUpResource <<Resource>> {
      + fullName: string
      + email: string
      + password: string
    }
    interface "UserResource" as Frontend_iam_UserResource <<Resource>> {
      + fullName: string
      + email: string
      + accessProfileId?: number
    }
  }
  package "Infrastructure / Responses" {
    interface "AccessProfileResponse" as Frontend_iam_AccessProfileResponse <<Response>> {
      + id: number
      + name: AccessProfileName
      + description: string
      + permissions: AccessPermission[]
    }
    interface "AuthResponse" as Frontend_iam_AuthResponse <<Response>> {
      + user: UserResponse
      + token: string
      + message?: string
    }
    interface "UserResponse" as Frontend_iam_UserResponse <<Response>> {
      + id: number
      + fullName: string
      + email: string
      + accessProfileId: number
      + accessProfileName: string
      + status?: string
      + createdAt: string
    }
  }
}

Frontend_iam_AuthApiService ..> Frontend_iam_ResetPasswordResource
Frontend_iam_AuthApiService ..> Frontend_iam_SignInResource
Frontend_iam_AuthApiService ..> Frontend_iam_SignUpResource
Frontend_iam_AuthApiService ..> Frontend_iam_AuthResponse
Frontend_iam_UsersApiService ..> Frontend_iam_AssignAccessProfileResource
Frontend_iam_UsersApiService ..> Frontend_iam_UserResource
Frontend_iam_UsersApiService ..> Frontend_iam_UserResponse
Frontend_iam_AccessProfilesApiService ..> Frontend_iam_AccessProfileResponse
Frontend_iam_AccessProfileAssembler ..> Frontend_iam_AccessProfileResponse
Frontend_iam_AccessProfileAssembler ..> Frontend_iam_AccessProfileResource
Frontend_iam_UserAssembler ..> Frontend_iam_UserResponse
Frontend_iam_UserAssembler ..> Frontend_iam_UserResource

@enduml
