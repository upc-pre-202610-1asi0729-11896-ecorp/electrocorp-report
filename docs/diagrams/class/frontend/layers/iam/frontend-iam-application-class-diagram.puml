@startuml
title ElectroCorp Web App - IAM Frontend Application Layer
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "IAM / Application" {
  package "Application / Commands" {
    interface "DeleteAccountCommand" as Frontend_iam_DeleteAccountCommand <<interface>> {
      + confirmation: string
    }
    interface "RecoverPasswordCommand" as Frontend_iam_RecoverPasswordCommand <<interface>> {
      + email: string
    }
    interface "ResetPasswordCommand" as Frontend_iam_ResetPasswordCommand <<interface>> {
      + token: string
      + password: string
      + confirmPassword: string
    }
    interface "SignInCommand" as Frontend_iam_SignInCommand <<interface>> {
      + email: string
      + password: string
    }
    interface "SignUpCommand" as Frontend_iam_SignUpCommand <<interface>> {
      + fullName: string
      + email: string
      + password: string
    }
    interface "UpdateProfileCommand" as Frontend_iam_UpdateProfileCommand <<interface>> {
      + fullName: string
      + email: string
    }
  }
  package "Application / Facades and Services" {
    class "IamFacade" as Frontend_iam_IamFacade <<Facade>> {
      - userAssembler: UserAssembler
      - accessProfileAssembler: AccessProfileAssembler
      - authApi: AuthApiService
      - accessProfilesApi: AccessProfilesApiService
      - usersApi: UsersApiService
      - authSession: AuthSessionService
      - router: Router
      - store: IamStore
      + currentUser() : User | null
      + users() : User[]
      + accessProfiles() : AccessProfile[]
      + loading() : boolean
      + error() : string | null
      + isAuthenticated() : boolean
      + signIn(command: SignInCommand) : Promise<boolean>
      + signUp(command: SignUpCommand, options: SignUpOptions) : Promise<boolean>
      + restoreSession() : Promise<boolean>
      + signOut() : Promise<void>
      + recoverPassword(command: RecoverPasswordCommand) : Promise<boolean>
      + resetPassword(command: ResetPasswordCommand) : Promise<boolean>
      + updateProfile(command: UpdateProfileCommand) : Promise<boolean>
      + deleteAccount(command: DeleteAccountCommand) : Promise<boolean>
      + loadAccessProfiles() : Promise<AccessProfile[]>
      + loadManagedUsers() : Promise<User[]>
      + assignAccessProfile(userId: number, accessProfileId: number) : Promise<boolean>
    }
  }
  package "Application / Stores" {
    class "IamStore" as Frontend_iam_IamStore <<Store>> {
      - currentUserSignal: Signal<User | null>
      - usersSignal: Signal<User[]>
      - accessProfilesSignal: Signal<AccessProfile[]>
      - loadingSignal: Signal<boolean>
      - errorSignal: Signal<string | null>
      + currentUser() : User | null
      + users() : User[]
      + accessProfiles() : AccessProfile[]
      + isAuthenticated() : boolean
      + setCurrentUser(user: User | null) : void
      + setUsers(users: User[]) : void
      + updateUser(user: User) : void
      + setAccessProfiles(profiles: AccessProfile[]) : void
      + setLoading(value: boolean) : void
      + setError(value: string | null) : void
      + reset() : void
    }
  }
}

Frontend_iam_IamFacade ..> Frontend_iam_IamStore
Frontend_iam_IamFacade ..> Frontend_iam_DeleteAccountCommand
Frontend_iam_IamFacade ..> Frontend_iam_RecoverPasswordCommand
Frontend_iam_IamFacade ..> Frontend_iam_ResetPasswordCommand
Frontend_iam_IamFacade ..> Frontend_iam_SignInCommand
Frontend_iam_IamFacade ..> Frontend_iam_SignUpCommand
Frontend_iam_IamFacade ..> Frontend_iam_UpdateProfileCommand

@enduml
