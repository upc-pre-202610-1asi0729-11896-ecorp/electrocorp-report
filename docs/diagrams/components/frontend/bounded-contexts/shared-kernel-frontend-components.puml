@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam wrapWidth 170
skinparam maxMessageSize 90
skinparam ArrowColor #6B6B6B
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle bold
skinparam packageStyle rectangle
skinparam packageBorderColor #555555
skinparam packageBackgroundColor transparent
skinparam packageFontColor #444444
skinparam packageFontStyle bold
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
hide stereotype
title ElectroCorp - Shared Kernel Frontend Components Diagram
left to right direction

package "Shared Kernel Frontend Bounded Context\n[container]" {
  rectangle "<b>App Layout Component</b>\n<i>[Angular Component]</i>\n\nPresents user interaction for this bounded context." as P0 #58A9E8
  rectangle "<b>Shared UI Components</b>\n<i>[Angular Component]</i>\n\nPresents user interaction for this bounded context." as P1 #58A9E8
  rectangle "<b>Language Switcher Component</b>\n<i>[Angular Component]</i>\n\nPresents user interaction for this bounded context." as P2 #58A9E8
  rectangle "<b>Shared UI Facade</b>\n<i>[Angular Service]</i>\n\nCoordinates state, use cases and REST calls." as Facade #58A9E8
  rectangle "<b>Base API Service</b>\n<i>[Angular Service]</i>\n\nConsumes backend endpoints for this context." as Client #58A9E8
}
rectangle "<b>ElectroCorp Backend API</b>\n<i>[External Container]</i>\n\nREST API consumed by this frontend context." as Backend #7F8C8D
package "Connected Frontend Contexts\n[external containers]" {
  rectangle "<b>IAM</b>\n<i>[Frontend Context]</i>\n\nProvides shared navigation, session or referenced data." as Dep0 #7F8C8D
  rectangle "<b>Billing</b>\n<i>[Frontend Context]</i>\n\nProvides shared navigation, session or referenced data." as Dep1 #7F8C8D
  rectangle "<b>Workplace</b>\n<i>[Frontend Context]</i>\n\nProvides shared navigation, session or referenced data." as Dep2 #7F8C8D
  rectangle "<b>Device Control</b>\n<i>[Frontend Context]</i>\n\nProvides shared navigation, session or referenced data." as Dep3 #7F8C8D
  rectangle "<b>Energy Monitoring</b>\n<i>[Frontend Context]</i>\n\nProvides shared navigation, session or referenced data." as Dep4 #7F8C8D
  rectangle "<b>Notifications</b>\n<i>[Frontend Context]</i>\n\nProvides shared navigation, session or referenced data." as Dep5 #7F8C8D
  rectangle "<b>Reporting</b>\n<i>[Frontend Context]</i>\n\nProvides shared navigation, session or referenced data." as Dep6 #7F8C8D
  rectangle "<b>Service Management</b>\n<i>[Frontend Context]</i>\n\nProvides shared navigation, session or referenced data." as Dep7 #7F8C8D
}
P0 --> Facade : Uses
P1 --> Facade : Uses
P2 --> Facade : Uses
Facade --> Client : Uses
Client --> Backend : Consumes REST endpoints\n[JSON / HTTPS]
Facade ..> Dep0 : Coordinates with
Facade ..> Dep1 : Coordinates with
Facade ..> Dep2 : Coordinates with
Facade ..> Dep3 : Coordinates with
Facade ..> Dep4 : Coordinates with
Facade ..> Dep5 : Coordinates with
Facade ..> Dep6 : Coordinates with
Facade ..> Dep7 : Coordinates with
legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#9B59B6> domain |
  |<#F39C12> repository / external |
  |<#C9332B> database |
endlegend
@enduml
