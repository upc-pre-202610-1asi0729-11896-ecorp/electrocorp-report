@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam wrapWidth 180
skinparam maxMessageSize 90
skinparam ArrowColor #6B6B6B
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 1
skinparam packageStyle rectangle
skinparam packageBorderColor #555555
skinparam packageBackgroundColor transparent
skinparam packageFontColor #444444
skinparam packageFontStyle bold
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
hide stereotype
title ElectroCorp - Shared Kernel Frontend Components Diagram
left to right direction


package "Shared Kernel Frontend Bounded Context\n[container]" {
  rectangle "App Layout Component\n[Angular Component]\n\nPresents user interaction for this bounded context." as F0 #58A9E8
  rectangle "Shared UI Components\n[Angular Component]\n\nPresents user interaction for this bounded context." as F1 #58A9E8
  rectangle "Language Switcher Component\n[Angular Component]\n\nPresents user interaction for this bounded context." as F2 #58A9E8
  rectangle "Auth Session Service\n[Angular Service]\n\nCoordinates state, use cases and REST calls." as F3 #58A9E8
  rectangle "Base API Service\n[Angular Service]\n\nCoordinates state, use cases and REST calls." as F4 #58A9E8
}
rectangle "ElectroCorp Backend API\n[External Container]\n\nREST API consumed by this frontend context." as Backend #7F8C8D
package "Connected Frontend Contexts\n[external containers]" {
  rectangle "IAM\n[Frontend Context]\n\nProvides shared navigation, session or referenced data." as Dep0 #7F8C8D
  rectangle "Billing\n[Frontend Context]\n\nProvides shared navigation, session or referenced data." as Dep1 #7F8C8D
  rectangle "Workplace\n[Frontend Context]\n\nProvides shared navigation, session or referenced data." as Dep2 #7F8C8D
  rectangle "Device Control\n[Frontend Context]\n\nProvides shared navigation, session or referenced data." as Dep3 #7F8C8D
  rectangle "Energy Monitoring\n[Frontend Context]\n\nProvides shared navigation, session or referenced data." as Dep4 #7F8C8D
  rectangle "Notifications\n[Frontend Context]\n\nProvides shared navigation, session or referenced data." as Dep5 #7F8C8D
  rectangle "Reporting\n[Frontend Context]\n\nProvides shared navigation, session or referenced data." as Dep6 #7F8C8D
  rectangle "Service Management\n[Frontend Context]\n\nProvides shared navigation, session or referenced data." as Dep7 #7F8C8D
}
F0 --> F3 : Uses
F1 --> F3 : Uses
F2 --> F3 : Uses
F3 --> F4 : Uses
F4 --> Backend : Consumes REST endpoints (JSON / HTTPS)
F3 ..> Dep0 : Coordinates with
F3 ..> Dep1 : Coordinates with
F3 ..> Dep2 : Coordinates with
F3 ..> Dep3 : Coordinates with
F3 ..> Dep4 : Coordinates with
F3 ..> Dep5 : Coordinates with
F3 ..> Dep6 : Coordinates with
F3 ..> Dep7 : Coordinates with
legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#F39C12> repository / external |
  |<#C9332B> database |
endlegend
@enduml
