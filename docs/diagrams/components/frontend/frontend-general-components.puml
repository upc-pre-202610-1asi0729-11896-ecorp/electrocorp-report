@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam wrapWidth 180
skinparam maxMessageSize 90
skinparam ArrowColor #6B6B6B
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 1
skinparam packageStyle rectangle
skinparam packageBorderColor #555555
skinparam packageBackgroundColor transparent
skinparam packageFontColor #444444
skinparam packageFontStyle bold
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
hide stereotype
title ElectroCorp - Frontend General Components Diagram
left to right direction


rectangle "ElectroCorp User\n[Person]\n\nUses the Angular SPA to manage energy operations." as User <#0B5593>
package "ElectroCorp Frontend / Angular SPA\n[container]" {
  rectangle "App Layout Component\n[Angular Component]\n\nMain shell, topbar, language switcher and router outlet." as Layout <#58A9E8>
  rectangle "App Router\n[Angular Router]\n\nRoutes users to each bounded context." as Router <#58A9E8>
  rectangle "Shared Kernel Context\n[Bounded Context]\n\nApp Layout Component, Shared UI Components, Language Switcher Component." as C0 <#3498DB>
  rectangle "IAM Context\n[Bounded Context]\n\nLogin/Register Pages, Account/Profile Pages, IAM Facade." as C1 <#3498DB>
  rectangle "Billing Context\n[Bounded Context]\n\nPlans Page, Billing History Page, Plan Card Component." as C2 <#3498DB>
  rectangle "Workplace Context\n[Bounded Context]\n\nLocations Page, Rooms Page, Device Assignments Page." as C3 <#3498DB>
  rectangle "Device Control Context\n[Bounded Context]\n\nDevices Page, Device Groups Page, Routines Page." as C4 <#3498DB>
  rectangle "Energy Monitoring Context\n[Bounded Context]\n\nEnergy Dashboard Page, Energy History Page, Metrics Components." as C5 <#3498DB>
  rectangle "Notifications Context\n[Bounded Context]\n\nAlerts Page, Alert Rules Page, Notification Preferences Page." as C6 <#3498DB>
  rectangle "Reporting Context\n[Bounded Context]\n\nReports Page, Energy Goals Page, Report Components." as C7 <#3498DB>
  rectangle "Service Management Context\n[Bounded Context]\n\nSupport Tickets Page, Maintenance Tickets Page, Ticket Components." as C8 <#3498DB>
  rectangle "Infrastructure API Clients\n[Angular HTTP Services]\n\nTyped services that call backend REST endpoints." as Clients <#F39C12>
}
rectangle "ElectroCorp Backend API\n[External Container]\n\nSpring Boot REST API consumed by Angular." as Backend <#7F8C8D>
User --> Layout : Uses
Layout --> Router : Displays routed views through
Router --> C0 : Routes to
Router --> C1 : Routes to
Router --> C2 : Routes to
Router --> C3 : Routes to
Router --> C4 : Routes to
Router --> C5 : Routes to
Router --> C6 : Routes to
Router --> C7 : Routes to
Router --> C8 : Routes to
C0 --> Clients : Uses
C1 --> Clients : Uses
C2 --> Clients : Uses
C3 --> Clients : Uses
C4 --> Clients : Uses
C5 --> Clients : Uses
C6 --> Clients : Uses
C7 --> Clients : Uses
C8 --> Clients : Uses
C1 --> C0 : Uses shared UI/services
C2 --> C0 : Uses shared UI/services
C3 --> C0 : Uses shared UI/services
C4 --> C0 : Uses shared UI/services
C5 --> C0 : Uses shared UI/services
C6 --> C0 : Uses shared UI/services
C7 --> C0 : Uses shared UI/services
C8 --> C0 : Uses shared UI/services
Clients --> Backend : Consumes REST endpoints (JSON / HTTPS)
legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#F39C12> repository / external |
  |<#C9332B> database |
endlegend
@enduml
