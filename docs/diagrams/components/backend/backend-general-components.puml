@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam wrapWidth 170
skinparam maxMessageSize 90
skinparam ArrowColor #6B6B6B
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle bold
skinparam packageStyle rectangle
skinparam packageBorderColor #555555
skinparam packageBackgroundColor transparent
skinparam packageFontColor #444444
skinparam packageFontStyle bold
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
hide stereotype
title ElectroCorp - Backend General Components Diagram
left to right direction

rectangle "<b>ElectroCorp Web App</b>\n<i>[External Container]</i>\n\nAngular SPA consuming backend services." as WebApp #7F8C8D
package "ElectroCorp Backend API / Spring Boot\n[container]" {
  rectangle "<b>REST API Entry Point</b>\n<i>[Spring Boot Application]</i>\n\nReceives HTTP requests and delegates them to bounded contexts." as Api #3498DB
  rectangle "<b>Shared Kernel API</b>\n<i>[Bounded Context Component]</i>\n\nShared Platform Service, controllers, services and repositories." as B0 #58A9E8
  rectangle "<b>IAM API</b>\n<i>[Bounded Context Component]</i>\n\nIdentity Access Service, controllers, services and repositories." as B1 #58A9E8
  rectangle "<b>Billing API</b>\n<i>[Bounded Context Component]</i>\n\nBilling Service, controllers, services and repositories." as B2 #58A9E8
  rectangle "<b>Workplace API</b>\n<i>[Bounded Context Component]</i>\n\nWorkplace Management Service, controllers, services and repositories." as B3 #58A9E8
  rectangle "<b>Device Control API</b>\n<i>[Bounded Context Component]</i>\n\nDevice Management Service, controllers, services and repositories." as B4 #58A9E8
  rectangle "<b>Energy Monitoring API</b>\n<i>[Bounded Context Component]</i>\n\nEnergy Monitoring Service, controllers, services and repositories." as B5 #58A9E8
  rectangle "<b>Notifications API</b>\n<i>[Bounded Context Component]</i>\n\nNotification Service, controllers, services and repositories." as B6 #58A9E8
  rectangle "<b>Reporting API</b>\n<i>[Bounded Context Component]</i>\n\nReporting Service, controllers, services and repositories." as B7 #58A9E8
  rectangle "<b>Service Management API</b>\n<i>[Bounded Context Component]</i>\n\nService Management Service, controllers, services and repositories." as B8 #58A9E8
}
database "<b>ElectroCorp Database</b>\n<i>[Relational Database]</i>\n\nStores backend data for every bounded context." as Database
