@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 220
skinparam maxMessageSize 130
skinparam nodesep 70
skinparam ranksep 80
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam ArrowThickness 1
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle plain
skinparam rectangle {
  BorderThickness 0
  MinimumWidth 190
  Padding 12
}
skinparam database {
  MinimumWidth 210
  Padding 12
}
skinparam rectangle<<SystemBoundary>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
  MinimumWidth 760
  Padding 18
}
skinparam rectangle<<BoundedContext>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
  MinimumWidth 760
  Padding 18
}
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
skinparam databaseFontStyle plain

hide stereotype
left to right direction

title ElectroCorp - Backend General Components Diagram

rectangle "<b>ElectroCorp SPA</b>\n<i>[Compiled Angular SPA]</i>\n\nBrowser runtime that consumes backend bounded context capabilities through HTTPS." as Spa #3498DB

rectangle "<b>ElectroCorp Backend Bounded Context Map</b>\n<i>[Spring Boot Modular Monolith / Backend Container]</i>" <<BoundedContext>> {

  rectangle "<b>Shared Kernel API</b>\n<i>[Bounded Context Component]</i>\n\nProvides shared security,\nOpenAPI, CORS, health\nchecks and common\nplatform configuration." as Shared #58A9E8

  rectangle "<b>IAM API</b>\n<i>[Bounded Context Component]</i>\n\nManages authentication,\nusers, profiles and\naccess control." as IAM #58A9E8

  rectangle "<b>Billing API</b>\n<i>[Bounded Context Component]</i>\n\nCoordinates plans,\nsubscriptions, payments\nand invoices." as Billing #58A9E8

  rectangle "<b>Workplace API</b>\n<i>[Bounded Context Component]</i>\n\nCoordinates locations,\nrooms and device\nassignments." as Workplace #58A9E8

  rectangle "<b>Device Control API</b>\n<i>[Bounded Context Component]</i>\n\nCoordinates devices,\ngroups, routines and\noperation modes." as Device #58A9E8

  rectangle "<b>Energy Monitoring API</b>\n<i>[Bounded Context Component]</i>\n\nCoordinates readings,\nsampling settings,\nstatistics and energy\ndashboards." as Energy #58A9E8

  rectangle "<b>Notifications API</b>\n<i>[Bounded Context Component]</i>\n\nCoordinates alerts,\nrules, preferences and\nnotification evaluation." as Notifications #58A9E8

  rectangle "<b>Reporting API</b>\n<i>[Bounded Context Component]</i>\n\nCoordinates reports,\nenergy goals, exports\nand platform insights." as Reporting #58A9E8

  rectangle "<b>Service Management API</b>\n<i>[Bounded Context Component]</i>\n\nCoordinates support\ntickets, maintenance\ntickets and service\nfollow-up." as Service #58A9E8
}

database "<b>ElectroCorp Database</b>\n<i>[PostgreSQL]</i>\n\nStores application data\nused by every bounded\ncontext." as Database

Spa --> Shared : Uses shared platform\nendpoints\n[JSON / HTTPS]
Spa --> IAM : Uses identity\nendpoints\n[JSON / HTTPS]
Spa --> Billing : Uses billing\nendpoints\n[JSON / HTTPS]
Spa --> Workplace : Uses workplace\nendpoints\n[JSON / HTTPS]
Spa --> Device : Uses operation\nendpoints\n[JSON / HTTPS]
Spa --> Energy : Uses energy\nendpoints\n[JSON / HTTPS]
Spa --> Notifications : Uses notification\nendpoints\n[JSON / HTTPS]
Spa --> Reporting : Uses reporting\nendpoints\n[JSON / HTTPS]
Spa --> Service : Uses service\nendpoints\n[JSON / HTTPS]

Shared --> Database : Reads and writes\n[JPA / SQL]
IAM --> Database : Reads and writes\n[JPA / SQL]
Billing --> Database : Reads and writes\n[JPA / SQL]
Workplace --> Database : Reads and writes\n[JPA / SQL]
Device --> Database : Reads and writes\n[JPA / SQL]
Energy --> Database : Reads and writes\n[JPA / SQL]
Notifications --> Database : Reads and writes\n[JPA / SQL]
Reporting --> Database : Reads and writes\n[JPA / SQL]
Service --> Database : Reads and writes\n[JPA / SQL]

Billing --> IAM : Validates user\nownership
Workplace --> IAM : Validates user\nownership
Device --> Workplace : Uses assigned\nspaces
Energy --> Device : Records device\nreadings
Notifications --> Energy : Evaluates energy\nconditions
Reporting --> Billing : Reads subscription\nmetrics
Reporting --> Workplace : Reads workplace\nmetrics
Reporting --> Device : Reads operation\nmetrics
Reporting --> Energy : Reads energy\nmetrics
Reporting --> Notifications : Reads alert\nmetrics
Reporting --> Service : Reads service\nmetrics

