@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 135
skinparam maxMessageSize 70
skinparam nodesep 35
skinparam ranksep 45
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam ArrowThickness 1
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle plain
skinparam rectangle {
  BorderThickness 0
  MinimumWidth 150
  Padding 8
}
skinparam database {
  MinimumWidth 165
  Padding 8
}
skinparam rectangle<<BoundedContext>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
  MinimumWidth 620
  Padding 12
}
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
skinparam databaseFontStyle plain

hide stereotype
top to bottom direction

title ElectroCorp - Backend General Components Diagram

rectangle "<b>ElectroCorp SPA</b>\n<i>[Compiled Angular SPA]</i>\n\nConsumes backend bounded context capabilities through HTTPS." as Spa #3498DB

rectangle "<b>ElectroCorp Backend Bounded Context Map</b>\n<i>[Spring Boot Modular Monolith / Backend Container]</i>" <<BoundedContext>> {
  rectangle "<b>REST API Surface</b>\n<i>[Spring Boot Entry Points]</i>\n\nReceives SPA requests and dispatches them to bounded contexts." as ApiSurface #3498DB

  rectangle "<b>Shared Kernel API</b>\n<i>[Bounded Context Component]</i>\n\nSecurity, OpenAPI, CORS, RestClient, health and common platform configuration." as Shared #58A9E8
  rectangle "<b>IAM API</b>\n<i>[Bounded Context Component]</i>\n\nAuthentication, users, profiles and access control." as IAM #58A9E8
  rectangle "<b>Billing API</b>\n<i>[Bounded Context Component]</i>\n\nPlans, subscriptions, payments and invoices." as Billing #58A9E8

  rectangle "<b>Workplace API</b>\n<i>[Bounded Context Component]</i>\n\nLocations, rooms and device assignments." as Workplace #58A9E8
  rectangle "<b>Device Control API</b>\n<i>[Bounded Context Component]</i>\n\nDevices, groups, routines and operation modes." as Device #58A9E8
  rectangle "<b>Energy Monitoring API</b>\n<i>[Bounded Context Component]</i>\n\nReadings, sampling, statistics and dashboards." as Energy #58A9E8

  rectangle "<b>Notifications API</b>\n<i>[Bounded Context Component]</i>\n\nAlerts, rules, preferences and evaluation." as Notifications #58A9E8
  rectangle "<b>Reporting API</b>\n<i>[Bounded Context Component]</i>\n\nReports, goals, exports and insights." as Reporting #58A9E8
  rectangle "<b>Service Management API</b>\n<i>[Bounded Context Component]</i>\n\nSupport tickets, maintenance and service follow-up." as Service #58A9E8

  rectangle "<b>Integration Event Bus</b>\n<i>[Spring Application Events]</i>\n\nPublishes committed domain activity as integration events for internal consumers." as EventBus #F39C12
  rectangle "<b>Persistence Access</b>\n<i>[Repositories / Adapters]</i>\n\nAggregates JPA repositories used by bounded contexts." as Persistence #F39C12
}

database "<b>ElectroCorp Database</b>\n<i>[PostgreSQL]</i>\n\nPersists data for all bounded contexts." as Database

Spa --> ApiSurface : JSON / HTTPS
ApiSurface --> Shared : route
ApiSurface --> IAM : route
ApiSurface --> Billing : route
ApiSurface --> Workplace : route
ApiSurface --> Device : route
ApiSurface --> Energy : route
ApiSurface --> Notifications : route
ApiSurface --> Reporting : route
ApiSurface --> Service : route

Billing --> IAM : user ownership
Workplace --> IAM : user scope
Device --> Workplace : assigned spaces
Energy --> Device : device readings
Notifications --> Energy : energy conditions
IAM --> EventBus : user registered
Billing --> EventBus : subscription / payment
Workplace --> EventBus : assignment
Device --> EventBus : device / mode
Energy --> EventBus : threshold
Service --> EventBus : service tickets
EventBus --> Notifications : CreateAlertCommand
EventBus --> Reporting : RecordReportingEventCommand
Reporting --> Billing : subscription metrics
Reporting --> Workplace : workplace metrics
Reporting --> Device : operation metrics
Reporting --> Energy : energy metrics
Reporting --> Notifications : alert metrics
Reporting --> Service : service metrics

Shared --> Persistence : persist
IAM --> Persistence : persist
Billing --> Persistence : persist
Workplace --> Persistence : persist
Device --> Persistence : persist
Energy --> Persistence : persist
Notifications --> Persistence : persist
Reporting --> Persistence : persist
Service --> Persistence : persist
Persistence --> Database : JPA / SQL

' Compact board layout
ApiSurface -[hidden]down- IAM
Shared -[hidden]right- IAM
IAM -[hidden]right- Billing
Shared -[hidden]down- Workplace
IAM -[hidden]down- Device
Billing -[hidden]down- Energy
Workplace -[hidden]right- Device
Device -[hidden]right- Energy
Workplace -[hidden]down- Notifications
Device -[hidden]down- Reporting
Energy -[hidden]down- Service
Energy -[hidden]right- EventBus
Notifications -[hidden]right- Reporting
Reporting -[hidden]right- Service
EventBus -[hidden]down- Persistence
Persistence -[hidden]down- Database

legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#C9332B> database |
endlegend

@enduml
