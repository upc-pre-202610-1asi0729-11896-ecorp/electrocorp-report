@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam wrapWidth 170
skinparam maxMessageSize 90
skinparam ArrowColor #6B6B6B
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle bold
skinparam packageStyle rectangle
skinparam packageBorderColor #555555
skinparam packageBackgroundColor transparent
skinparam packageFontColor #444444
skinparam packageFontStyle bold
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
hide stereotype
title ElectroCorp - Workplace Backend Components Diagram
left to right direction

package "Workplace Backend Bounded Context\n[container]" {
  rectangle "<b>Workplace Management Service</b>\n<i>[Application Service]</i>\n\nCoordinates locations, rooms and device assignments." as Service #3498DB
  rectangle "<b>Create Location Command</b>\n<i>[Command]</i>\n\nInput data to execute this use case." as C0 #3498DB
  rectangle "<b>Create Room Command</b>\n<i>[Command]</i>\n\nInput data to execute this use case." as C1 #3498DB
  rectangle "<b>Assign Device Command</b>\n<i>[Command]</i>\n\nInput data to execute this use case." as C2 #3498DB
  rectangle "<b>Assignment Policy</b>\n<i>[Domain Service]</i>\n\nApplies business rules for this bounded context." as D0 #9B59B6
  rectangle "<b>Location Policy</b>\n<i>[Domain Service]</i>\n\nApplies business rules for this bounded context." as D1 #9B59B6
  rectangle "<b>Location</b>\n<i>[Domain Entity]</i>\n\nRepresents location business state." as E0 #9B59B6
  rectangle "<b>Room</b>\n<i>[Domain Entity]</i>\n\nRepresents room business state." as E1 #9B59B6
  rectangle "<b>Device Assignment</b>\n<i>[Domain Entity]</i>\n\nRepresents device assignment business state." as E2 #9B59B6
  rectangle "<b>Address</b>\n<i>[Value Object]</i>\n\nRepresents address value." as V0 #9B59B6
  rectangle "<b>Room Name</b>\n<i>[Value Object]</i>\n\nRepresents room name value." as V1 #9B59B6
  rectangle "<b>Location Repository</b>\n<i>[Spring Data Repository]</i>\n\nPersists location data." as R0 #F39C12
  rectangle "<b>Room Repository</b>\n<i>[Spring Data Repository]</i>\n\nPersists room data." as R1 #F39C12
  rectangle "<b>Device Assignment Repository</b>\n<i>[Spring Data Repository]</i>\n\nPersists device assignment data." as R2 #F39C12
}
database "<b>ElectroCorp Database</b>\n<i>[Relational Database]</i>\n\nStores locations, rooms and assignments." as Database
package "Connected Bounded Contexts\n[external containers]" {
  rectangle "<b>IAM</b>\n<i>[Bounded Context]</i>\n\nProvides referenced capability or published language." as Dep0 #7F8C8D
  rectangle "<b>Device Control</b>\n<i>[Bounded Context]</i>\n\nProvides referenced capability or published language." as Dep1 #7F8C8D
  rectangle "<b>Reporting</b>\n<i>[Bounded Context]</i>\n\nProvides referenced capability or published language." as Dep2 #7F8C8D
  rectangle "<b>Shared Kernel</b>\n<i>[Bounded Context]</i>\n\nProvides referenced capability or published language." as Dep3 #7F8C8D
}
Service --> C0 : Receives
Service --> C1 : Receives
Service --> C2 : Receives
Service --> D0 : Uses
Service --> D1 : Uses
Service --> R0 : Uses
Service --> R1 : Uses
Service --> R2 : Uses
D0 --> E0 : Validates
D1 --> E1 : Validates
E0 --> V0 : Has
E0 --> V1 : Has
E1 --> V1 : Has
R0 --> Database : Reads and writes
R1 --> Database : Reads and writes
R2 --> Database : Reads and writes
Service ..> Dep0 : Coordinates with
Service ..> Dep1 : Coordinates with
Service ..> Dep2 : Coordinates with
Service ..> Dep3 : Coordinates with
legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#9B59B6> domain |
  |<#F39C12> repository / external |
  |<#C9332B> database |
endlegend
@enduml
