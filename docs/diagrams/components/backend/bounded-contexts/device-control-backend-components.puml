hide stereotype
title ElectroCorp - Device Control Backend Components Diagram
left to right direction

package "Device Control Backend Bounded Context\n[container]" {
  rectangle "<b>Device Management Service</b>\n<i>[Application Service]</i>\n\nCoordinates devices, groups, routines and operation modes." as Service #3498DB
  rectangle "<b>Create Device Command</b>\n<i>[Command]</i>\n\nInput data to execute this use case." as C0 #3498DB
  rectangle "<b>Update Device Status Command</b>\n<i>[Command]</i>\n\nInput data to execute this use case." as C1 #3498DB
  rectangle "<b>Create Routine Command</b>\n<i>[Command]</i>\n\nInput data to execute this use case." as C2 #3498DB
  rectangle "<b>Create Device Group Command</b>\n<i>[Command]</i>\n\nInput data to execute this use case." as C3 #3498DB
  rectangle "<b>Routine Policy</b>\n<i>[Domain Service]</i>\n\nApplies business rules for this bounded context." as D0 #9B59B6
  rectangle "<b>Power Calculator</b>\n<i>[Domain Service]</i>\n\nApplies business rules for this bounded context." as D1 #9B59B6
  rectangle "<b>Device</b>\n<i>[Domain Entity]</i>\n\nRepresents device business state." as E0 #9B59B6
  rectangle "<b>Device Group</b>\n<i>[Domain Entity]</i>\n\nRepresents device group business state." as E1 #9B59B6
  rectangle "<b>Routine</b>\n<i>[Domain Entity]</i>\n\nRepresents routine business state." as E2 #9B59B6
  rectangle "<b>Device Status</b>\n<i>[Value Object]</i>\n\nRepresents device status value." as V0 #9B59B6
  rectangle "<b>Device Type</b>\n<i>[Value Object]</i>\n\nRepresents device type value." as V1 #9B59B6
  rectangle "<b>Power Rating</b>\n<i>[Value Object]</i>\n\nRepresents power rating value." as V2 #9B59B6
  rectangle "<b>Schedule</b>\n<i>[Value Object]</i>\n\nRepresents schedule value." as V3 #9B59B6
  rectangle "<b>Device Repository</b>\n<i>[Spring Data Repository]</i>\n\nPersists device data." as R0 #F39C12
  rectangle "<b>Device Group Repository</b>\n<i>[Spring Data Repository]</i>\n\nPersists device group data." as R1 #F39C12
  rectangle "<b>Routine Repository</b>\n<i>[Spring Data Repository]</i>\n\nPersists routine data." as R2 #F39C12
}
database "<b>ElectroCorp Database</b>\n<i>[Relational Database]</i>\n\nStores devices, device groups, routines and operation modes." as Database
package "Connected Bounded Contexts\n[external containers]" {
  rectangle "<b>Workplace</b>\n<i>[Bounded Context]</i>\n\nProvides referenced capability or published language." as Dep0 #7F8C8D
  rectangle "<b>Energy Monitoring</b>\n<i>[Bounded Context]</i>\n\nProvides referenced capability or published language." as Dep1 #7F8C8D
  rectangle "<b>Notifications</b>\n<i>[Bounded Context]</i>\n\nProvides referenced capability or published language." as Dep2 #7F8C8D
  rectangle "<b>Reporting</b>\n<i>[Bounded Context]</i>\n\nProvides referenced capability or published language." as Dep3 #7F8C8D
  rectangle "<b>Shared Kernel</b>\n<i>[Bounded Context]</i>\n\nProvides referenced capability or published language." as Dep4 #7F8C8D
}
Service --> C0 : Receives
Service --> C1 : Receives
