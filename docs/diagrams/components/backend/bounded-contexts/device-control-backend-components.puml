@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 145
skinparam maxMessageSize 95
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam ArrowThickness 1
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle plain
skinparam rectangle {
  BorderThickness 0
}
skinparam rectangle<<BoundedContext>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
}
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
skinparam databaseFontStyle plain
hide stereotype
left to right direction

title ElectroCorp - Device Control Backend Components Diagram

rectangle "<b>Device Control Backend Bounded Context</b>\n<i>[Spring Boot Module]</i>" as Boundary <<BoundedContext>> {
  rectangle "<b>Interfaces REST Layer</b>\n<i>[REST / Resources]</i>\n\nControllers expose HTTP endpoints and translate resources into application requests." as Interfaces #58A9E8
  rectangle "<b>Application Layer</b>\n<i>[Commands / Queries / Services]</i>\n\nCoordinates use cases, transactions, commands, queries and application services." as Application #58A9E8
  rectangle "<b>Domain Layer</b>\n<i>[Aggregates / Policies]</i>\n\nOwns business rules, aggregates, entities, value objects, events and domain services." as Domain #58A9E8
  rectangle "<b>Infrastructure Layer</b>\n<i>[Persistence / Adapters]</i>\n\nImplements repositories, persistence mappings, ACL adapters and technical integrations." as Infrastructure #58A9E8
}

database "<b>ElectroCorp Database</b>\n<i>[PostgreSQL]</i>\n\nStores devices, device groups, routines and operation modes." as Database
rectangle "<b>Shared Kernel</b>\n<i>[Published Language]</i>\n\nProvides common errors, security context and shared platform configuration." as Shared #7F8C8D
rectangle "<b>Workplace</b>\n<i>[External Bounded Context]</i>\n\nCollaborates through IDs, published language or REST/application contracts." as Dep0 #7F8C8D
rectangle "<b>Energy Monitoring</b>\n<i>[External Bounded Context]</i>\n\nCollaborates through IDs, published language or REST/application contracts." as Dep1 #7F8C8D
rectangle "<b>Notifications</b>\n<i>[External Bounded Context]</i>\n\nCollaborates through IDs, published language or REST/application contracts." as Dep2 #7F8C8D
rectangle "<b>Reporting</b>\n<i>[External Bounded Context]</i>\n\nCollaborates through IDs, published language or REST/application contracts." as Dep3 #7F8C8D

Interfaces --> Application : Delegates use cases
Application --> Domain : Enforces business rules
Application --> Infrastructure : Uses ports / repositories
Infrastructure --> Domain : Maps persisted state
Infrastructure --> Database : Reads and writes
Interfaces ..> Shared : Uses platform contracts
Application ..> Shared : Uses shared language
Application ..> Dep0 : Coordinates with
Application ..> Dep1 : Coordinates with
Application ..> Dep2 : Coordinates with
Application ..> Dep3 : Coordinates with

Interfaces -[hidden]right- Application
Application -[hidden]right- Domain
Domain -[hidden]right- Infrastructure

legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#F39C12> infrastructure / external |
  |<#C9332B> database |
  |<#7F8C8D> external container |
endlegend

@enduml
