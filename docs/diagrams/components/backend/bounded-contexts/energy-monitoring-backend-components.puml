@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam wrapWidth 180
skinparam maxMessageSize 90
skinparam ArrowColor #6B6B6B
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 1
skinparam packageStyle rectangle
skinparam packageBorderColor #555555
skinparam packageBackgroundColor transparent
skinparam packageFontColor #444444
skinparam packageFontStyle bold
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
hide stereotype
title ElectroCorp - Energy Monitoring Backend Components Diagram
left to right direction


package "Energy Monitoring Backend Bounded Context\n[container]" {
  rectangle "Energy Monitoring Controller\n[REST Controller]\n\nExposes HTTP endpoints for this bounded context." as B0 #3498DB
  rectangle "Reading Application Service\n[Application Service]\n\nCoordinates commands, queries and use cases." as B1 #3498DB
  rectangle "Dashboard Query Service\n[Application Service]\n\nCoordinates commands, queries and use cases." as B2 #3498DB
  rectangle "Sampling Settings Service\n[Application Service]\n\nCoordinates commands, queries and use cases." as B3 #3498DB
  rectangle "Energy Reading Repository\n[Spring Data Repository]\n\nPersists and retrieves bounded context data." as R0 #F39C12
  rectangle "Sampling Settings Repository\n[Spring Data Repository]\n\nPersists and retrieves bounded context data." as R1 #F39C12
}
database "ElectroCorp Database\n[Relational Database]\n\nStores energy readings and sampling settings." as Database
package "Connected Bounded Contexts\n[external containers]" {
  rectangle "Device Control\n[Bounded Context]\n\nProvides referenced capability or published language." as Dep0 #7F8C8D
  rectangle "Reporting\n[Bounded Context]\n\nProvides referenced capability or published language." as Dep1 #7F8C8D
  rectangle "Notifications\n[Bounded Context]\n\nProvides referenced capability or published language." as Dep2 #7F8C8D
  rectangle "Shared Kernel\n[Bounded Context]\n\nProvides referenced capability or published language." as Dep3 #7F8C8D
}
B0 --> B1 : Delegates to
B0 --> B2 : Delegates to
B0 --> B3 : Delegates to
B1 --> R0 : Uses
B2 --> R1 : Uses
R0 --> Database : Reads and writes
R1 --> Database : Reads and writes
B0 ..> Dep0 : Coordinates with
B0 ..> Dep1 : Coordinates with
B0 ..> Dep2 : Coordinates with
B0 ..> Dep3 : Coordinates with
legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#F39C12> repository / external |
  |<#C9332B> database |
endlegend
@enduml
