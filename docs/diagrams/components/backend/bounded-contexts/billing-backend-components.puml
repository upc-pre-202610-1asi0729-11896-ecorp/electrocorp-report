@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultTextAlignment center
skinparam wrapWidth 220
skinparam maxMessageSize 130
skinparam nodesep 70
skinparam ranksep 80
skinparam ArrowColor #8A8A8A
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam ArrowThickness 1
skinparam rectangleRoundCorner 0
skinparam rectangleBorderThickness 0
skinparam rectangleFontColor #FFFFFF
skinparam rectangleFontStyle plain
skinparam rectangle {
  BorderThickness 0
  MinimumWidth 190
  Padding 12
}
skinparam database {
  MinimumWidth 210
  Padding 12
}
skinparam rectangle<<SystemBoundary>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
  MinimumWidth 760
  Padding 18
}
skinparam rectangle<<BoundedContext>> {
  BackgroundColor transparent
  BorderColor #4A4A4A
  BorderThickness 2
  BorderStyle dashed
  FontColor #333333
  FontStyle bold
  MinimumWidth 760
  Padding 18
}
skinparam databaseBackgroundColor #C9332B
skinparam databaseBorderColor #C9332B
skinparam databaseFontColor #FFFFFF
skinparam databaseFontStyle plain
hide stereotype
top to bottom direction

title ElectroCorp - Billing Backend Components Diagram

rectangle "<b>ElectroCorp SPA</b>\n<i>[Compiled Angular SPA]</i>\n\nBrowser runtime that consumes this bounded context through HTTPS." as Spa #3498DB

rectangle "<b>Billing Backend Bounded Context</b>\n<i>[Spring Boot Module]</i>" <<BoundedContext>> {
  rectangle "<b>Interfaces REST Layer</b>\n<i>[REST / Resources]</i>\n\nControllers expose HTTP endpoints and translate resources into application requests." as Interfaces #58A9E8
  rectangle "<b>Application Layer</b>\n<i>[Commands / Queries / Gateway Port]</i>\n\nCoordinates checkout, subscription activation, payments, invoices and payment gateway requests." as Application #58A9E8
  rectangle "<b>Domain Layer</b>\n<i>[Aggregates / Policies]</i>\n\nOwns plans, subscriptions, payments, invoices and payment validation rules." as Domain #58A9E8
  rectangle "<b>Infrastructure Layer</b>\n<i>[JPA / Stripe Adapter]</i>\n\nImplements persistence and the Stripe payment gateway adapter with demo fallback when credentials are absent." as Infrastructure #58A9E8
}
database "<b>ElectroCorp Database</b>\n<i>[PostgreSQL]</i>\n\nStores plans, subscriptions, payments and invoices." as Database
rectangle "<b>Stripe API</b>\n<i>[External Payment Provider]</i>\n\nReceives payment intent requests when integration credentials are configured." as Stripe #F39C12

Spa --> Interfaces : Calls REST endpoints\n[JSON / HTTPS]
Interfaces --> Application : Delegates use cases
Application --> Domain : Enforces business rules
Application --> Infrastructure : Uses ports / repositories
Infrastructure --> Domain : Maps persisted state
Infrastructure --> Database : Reads and writes
Infrastructure --> Stripe : Creates payment intents

Spa -[hidden]down- Interfaces
Interfaces -[hidden]down- Application
Application -[hidden]down- Domain
Domain -[hidden]right- Infrastructure
Infrastructure -[hidden]down- Database
Infrastructure -[hidden]right- Stripe

legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#F39C12> infrastructure / external |
  |<#C9332B> database |
  |<#7F8C8D> external container |
endlegend

@enduml
