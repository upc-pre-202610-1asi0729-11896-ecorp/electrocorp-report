@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam wrapWidth 180
skinparam maxMessageSize 90
skinparam defaultFontName Arial
skinparam ArrowColor #1F4E79
skinparam component {
  BackgroundColor #F8FBFF
  BorderColor #1F4E79
  FontColor #0B1F33
}
skinparam database {
  BackgroundColor #FFF9E8
  BorderColor #8A6D1D
}
skinparam actor {
  BackgroundColor #EEF7FF
  BorderColor #1F4E79
}

title ElectroCorp - Service Management Components
left to right direction

actor "User" as User
component "Angular Router" as Router
component "HTTP API Layer" as Http
component "Spring Boot API" as Api
database "PostgreSQL tables" as Db

package "Service Management Frontend" {
  component "Support Tickets Page" as Front_0
  component "Maintenance Tickets Page" as Front_1
  component "Ticket Cards" as Front_2
  component "Status Badge" as Front_3
  component "Service Management Facade" as Front_4
}

package "Service Management Backend" {
  component "REST Interface" as Backend_service_management
  component "Service Management Controller" as Back_0
  component "Support Ticket Service" as Back_1
  component "Maintenance Ticket Service" as Back_2
  component "Ticket Status Service" as Back_3
  component "Service Query Service" as Back_4
}

package "Service Management Persistence" {
  database "support_tickets" as Table_0
  database "maintenance_tickets" as Table_1
}

package "Connected bounded contexts" {
  component "IAM" as Dep0
  component "Device Control" as Dep1
  component "Workplace" as Dep2
  component "Shared Kernel" as Dep3
}

User --> Router
Router --> Front_0
Front_0 --> Front_1
Front_1 --> Front_2
Front_2 --> Front_3
Front_3 --> Front_4
Front_4 --> Http
Http --> Api
Api --> Backend_service_management
Backend_service_management --> Back_0
Back_0 --> Back_1
Back_1 --> Back_2
Back_2 --> Back_3
Back_3 --> Back_4
Back_4 --> Table_0
Table_0 ..> Table_1
Backend_service_management ..> Dep0 : uses / references
Backend_service_management ..> Dep1 : uses / references
Backend_service_management ..> Dep2 : uses / references
Backend_service_management ..> Dep3 : uses / references
@enduml
