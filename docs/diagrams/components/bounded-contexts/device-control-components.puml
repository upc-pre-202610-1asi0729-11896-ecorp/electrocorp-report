@startuml
!pragma layout smetana
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Arial
skinparam wrapWidth 180
skinparam maxMessageSize 90
skinparam ArrowColor #6B6B6B
skinparam ArrowFontColor #666666
skinparam ArrowFontStyle bold
skinparam rectangle {
  RoundCorner 0
  BorderThickness 1
}
skinparam package {
  BorderColor #555555
  BorderStyle dashed
  BackgroundColor transparent
  FontColor #444444
  FontStyle bold
}
skinparam database {
  BackgroundColor #C9332B
  BorderColor #C9332B
  FontColor #FFFFFF
}
hide stereotype
title ElectroCorp - Device Control Components Diagram
left to right direction


package "Device Control Frontend Bounded Context
[container]" {
  rectangle "<b>Devices Page</b>
<size:12><i>[Angular Component]</i></size>

Presents and coordinates user interaction." as F0 <#58A9E8>
  rectangle "<b>Device Groups Page</b>
<size:12><i>[Angular Component]</i></size>

Presents and coordinates user interaction." as F1 <#58A9E8>
  rectangle "<b>Routines Page</b>
<size:12><i>[Angular Component]</i></size>

Presents and coordinates user interaction." as F2 <#58A9E8>
  rectangle "<b>Device Control Facade</b>
<size:12><i>[Angular Service]</i></size>

Coordinates frontend state and REST calls." as F3 <#58A9E8>
  rectangle "<b>Device Control API Clients</b>
<size:12><i>[Angular Service]</i></size>

Coordinates frontend state and REST calls." as F4 <#58A9E8>
}

package "Device Control Backend Bounded Context
[container]" {
  rectangle "<b>Device Control Controller</b>
<size:12><i>[REST Controller]</i></size>

Exposes HTTP endpoints for this bounded context." as B0 <#3498DB>
  rectangle "<b>Device Application Service</b>
<size:12><i>[Application Service]</i></size>

Coordinates commands, queries and use cases." as B1 <#3498DB>
  rectangle "<b>Device Group Application Service</b>
<size:12><i>[Application Service]</i></size>

Coordinates commands, queries and use cases." as B2 <#3498DB>
  rectangle "<b>Routine Application Service</b>
<size:12><i>[Application Service]</i></size>

Coordinates commands, queries and use cases." as B3 <#3498DB>
  rectangle "<b>Device Repository</b>
<size:12><i>[Spring Data Repository]</i></size>

Persists and retrieves bounded context data." as R0 <#F39C12>
  rectangle "<b>Device Group Repository</b>
<size:12><i>[Spring Data Repository]</i></size>

Persists and retrieves bounded context data." as R1 <#F39C12>
  rectangle "<b>Routine Repository</b>
<size:12><i>[Spring Data Repository]</i></size>

Persists and retrieves bounded context data." as R2 <#F39C12>
}

database "<b>ElectroCorp Database</b>
<size:12><i>[Relational Database]</i></size>

Stores devices, device groups, routines and operation modes." as Database

package "Connected Bounded Contexts
[external containers]" {
  rectangle "<b>Workplace</b>
<size:12><i>[Bounded Context]</i></size>

Provides referenced capability or published language." as Dep0 <#7F8C8D>
  rectangle "<b>Energy Monitoring</b>
<size:12><i>[Bounded Context]</i></size>

Provides referenced capability or published language." as Dep1 <#7F8C8D>
  rectangle "<b>Notifications</b>
<size:12><i>[Bounded Context]</i></size>

Provides referenced capability or published language." as Dep2 <#7F8C8D>
  rectangle "<b>Shared Kernel</b>
<size:12><i>[Bounded Context]</i></size>

Provides referenced capability or published language." as Dep3 <#7F8C8D>
}

F0 --> F3 : Uses
F1 --> F3 : Uses
F2 --> F3 : Uses
F3 --> F4 : Uses
F4 --> B0 : Consumes REST endpoints (JSON / HTTPS)
B0 --> B1 : Delegates to
B0 --> B2 : Delegates to
B0 --> B3 : Delegates to
B1 --> R0 : Uses
B2 --> R1 : Uses
B3 --> R2 : Uses
R0 --> Database : Reads and writes
R1 --> Database : Reads and writes
R2 --> Database : Reads and writes
B0 ..> Dep0 : Coordinates with
B0 ..> Dep1 : Coordinates with
B0 ..> Dep2 : Coordinates with
B0 ..> Dep3 : Coordinates with
legend right
  <b>Legend</b>
  |<#0B5593> person |
  |<#0B6FB3> system |
  |<#3498DB> container |
  |<#58A9E8> component |
  |<#F39C12> repository / external |
  |<#C9332B> database |
endlegend
@enduml
