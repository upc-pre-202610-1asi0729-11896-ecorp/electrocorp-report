@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam wrapWidth 180
skinparam maxMessageSize 90
skinparam defaultFontName Arial
skinparam ArrowColor #1F4E79
skinparam component {
  BackgroundColor #F8FBFF
  BorderColor #1F4E79
  FontColor #0B1F33
}
skinparam database {
  BackgroundColor #FFF9E8
  BorderColor #8A6D1D
}
skinparam actor {
  BackgroundColor #EEF7FF
  BorderColor #1F4E79
}

title ElectroCorp - Device Control Components
left to right direction

actor "User" as User
component "Angular Router" as Router
component "HTTP API Layer" as Http
component "Spring Boot API" as Api
database "PostgreSQL tables" as Db

package "Device Control Frontend" {
  component "Devices Page" as Front_0
  component "Device Groups Page" as Front_1
  component "Routines Page" as Front_2
  component "Operation Modes Page" as Front_3
  component "Device Control Facade" as Front_4
}

package "Device Control Backend" {
  component "REST Interface" as Backend_device_control
  component "Device Control Controller" as Back_0
  component "Device Command Service" as Back_1
  component "Device Group Command Service" as Back_2
  component "Routine Command Service" as Back_3
  component "Operation Mode Service" as Back_4
}

package "Device Control Persistence" {
  database "devices" as Table_0
  database "device_groups" as Table_1
  database "routines" as Table_2
  database "operation_modes" as Table_3
}

package "Connected bounded contexts" {
  component "Workplace" as Dep0
  component "Energy Monitoring" as Dep1
  component "Notifications" as Dep2
  component "Shared Kernel" as Dep3
}

User --> Router
Router --> Front_0
Front_0 --> Front_1
Front_1 --> Front_2
Front_2 --> Front_3
Front_3 --> Front_4
Front_4 --> Http
Http --> Api
Api --> Backend_device_control
Backend_device_control --> Back_0
Back_0 --> Back_1
Back_1 --> Back_2
Back_2 --> Back_3
Back_3 --> Back_4
Back_4 --> Table_0
Table_0 ..> Table_1
Table_1 ..> Table_2
Table_2 ..> Table_3
Backend_device_control ..> Dep0 : uses / references
Backend_device_control ..> Dep1 : uses / references
Backend_device_control ..> Dep2 : uses / references
Backend_device_control ..> Dep3 : uses / references
@enduml
