@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam wrapWidth 180
skinparam maxMessageSize 90
skinparam defaultFontName Arial
skinparam ArrowColor #1F4E79
skinparam component {
  BackgroundColor #F8FBFF
  BorderColor #1F4E79
  FontColor #0B1F33
}
skinparam database {
  BackgroundColor #FFF9E8
  BorderColor #8A6D1D
}
skinparam actor {
  BackgroundColor #EEF7FF
  BorderColor #1F4E79
}

title ElectroCorp - IAM Components
left to right direction

actor "User" as User
component "Angular Router" as Router
component "HTTP API Layer" as Http
component "Spring Boot API" as Api
database "PostgreSQL tables" as Db

package "IAM Frontend" {
  component "Login/Register Pages" as Front_0
  component "Account/Profile Pages" as Front_1
  component "IAM Facade" as Front_2
  component "IAM Store" as Front_3
  component "Auth API Service" as Front_4
}

package "IAM Backend" {
  component "REST Interface" as Backend_iam
  component "Auth Controller" as Back_0
  component "User Controller" as Back_1
  component "Sign In/Sign Up Command Services" as Back_2
  component "User Query Service" as Back_3
  component "JWT Token Service" as Back_4
}

package "IAM Persistence" {
  database "users" as Table_0
  database "access_profiles" as Table_1
}

package "Connected bounded contexts" {
  component "Billing" as Dep0
  component "Shared Kernel" as Dep1
}

User --> Router
Router --> Front_0
Front_0 --> Front_1
Front_1 --> Front_2
Front_2 --> Front_3
Front_3 --> Front_4
Front_4 --> Http
Http --> Api
Api --> Backend_iam
Backend_iam --> Back_0
Back_0 --> Back_1
Back_1 --> Back_2
Back_2 --> Back_3
Back_3 --> Back_4
Back_4 --> Table_0
Table_0 ..> Table_1
Backend_iam ..> Dep0 : uses / references
Backend_iam ..> Dep1 : uses / references
@enduml
