@startuml
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam wrapWidth 180
skinparam maxMessageSize 90
skinparam defaultFontName Arial
skinparam ArrowColor #1F4E79
skinparam component {
  BackgroundColor #F8FBFF
  BorderColor #1F4E79
  FontColor #0B1F33
}
skinparam database {
  BackgroundColor #FFF9E8
  BorderColor #8A6D1D
}
skinparam actor {
  BackgroundColor #EEF7FF
  BorderColor #1F4E79
}

title ElectroCorp - Reporting Components
left to right direction

actor "User" as User
component "Angular Router" as Router
component "HTTP API Layer" as Http
component "Spring Boot API" as Api
database "PostgreSQL tables" as Db

package "Reporting Frontend" {
  component "Reports Page" as Front_0
  component "Energy Goals Page" as Front_1
  component "Report Card" as Front_2
  component "Goal Progress Card" as Front_3
  component "Reporting Facade" as Front_4
}

package "Reporting Backend" {
  component "REST Interface" as Backend_reporting
  component "Reporting Controller" as Back_0
  component "Platform Insight Controller" as Back_1
  component "Consumption Report Service" as Back_2
  component "Energy Goal Service" as Back_3
  component "Report Summary Service" as Back_4
}

package "Reporting Persistence" {
  database "consumption_reports" as Table_0
  database "energy_goals" as Table_1
}

package "Connected bounded contexts" {
  component "Energy Monitoring" as Dep0
  component "Workplace" as Dep1
  component "Device Control" as Dep2
  component "Shared Kernel" as Dep3
}

User --> Router
Router --> Front_0
Front_0 --> Front_1
Front_1 --> Front_2
Front_2 --> Front_3
Front_3 --> Front_4
Front_4 --> Http
Http --> Api
Api --> Backend_reporting
Backend_reporting --> Back_0
Back_0 --> Back_1
Back_1 --> Back_2
Back_2 --> Back_3
Back_3 --> Back_4
Back_4 --> Table_0
Table_0 ..> Table_1
Backend_reporting ..> Dep0 : uses / references
Backend_reporting ..> Dep1 : uses / references
Backend_reporting ..> Dep2 : uses / references
Backend_reporting ..> Dep3 : uses / references
@enduml
